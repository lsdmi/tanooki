<div class="space-y-10">
  <section>
    <p class="mb-3 text-sm font-medium text-gray-500">Desktop table row</p>
    <div class="rounded-xl border border-gray-200 bg-white shadow-sm">
      <div class="overflow-x-auto rounded-lg">
        <table class="w-full divide-y divide-gray-200 text-left text-sm text-gray-900">
          <thead class="bg-cyan-50 text-xs uppercase text-gray-700">
            <tr>
              <th scope="col" class="whitespace-nowrap p-4 text-xs font-semibold uppercase text-gray-500">Розділ</th>
              <th scope="col" class="whitespace-nowrap p-4 text-xs font-semibold uppercase text-gray-500">Статистика</th>
              <th scope="col" class="whitespace-nowrap p-4 text-xs font-semibold uppercase text-gray-500">Дії</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <%= render Readings::ChapterRowComponent.new(chapter:, variant: :table_row, pagy_page: 1) %>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section>
    <p class="mb-3 text-sm font-medium text-gray-500">Mobile card</p>
    <div class="max-w-md rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
      <%= render Readings::ChapterRowComponent.new(chapter:, variant: :card, pagy_page: 1) %>
    </div>
  </section>

  <section class="dark">
    <p class="mb-3 text-sm font-medium text-gray-400">Dark</p>
    <div class="space-y-8 rounded-xl bg-gray-950 p-8">
      <div class="rounded-xl border border-gray-700 bg-gray-800 shadow-sm">
        <div class="overflow-x-auto rounded-lg">
          <table class="w-full divide-y divide-gray-700 text-left text-sm text-white">
            <thead class="bg-rose-900/20 text-xs uppercase text-gray-400">
              <tr>
                <th scope="col" class="whitespace-nowrap p-4 text-xs font-semibold uppercase text-gray-300">Розділ</th>
                <th scope="col" class="whitespace-nowrap p-4 text-xs font-semibold uppercase text-gray-300">Статистика</th>
                <th scope="col" class="whitespace-nowrap p-4 text-xs font-semibold uppercase text-gray-300">Дії</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-700">
              <%= render Readings::ChapterRowComponent.new(chapter:, variant: :table_row, pagy_page: 1) %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="max-w-md rounded-xl border border-gray-700 bg-gray-800 p-6 shadow-sm">
        <%= render Readings::ChapterRowComponent.new(chapter:, variant: :card, pagy_page: 1) %>
      </div>
    </div>
  </section>
</div>
