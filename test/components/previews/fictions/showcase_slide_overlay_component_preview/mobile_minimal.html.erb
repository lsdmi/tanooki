<%# locals: slide: %>
<div class="max-w-sm">
  <p class="mb-3 text-sm font-medium text-gray-500">Genre page showcase — mobile (&lt; sm)</p>
  <%= render 'fictions/showcase_slide_overlay_component_preview/slide_frame', slide: slide %>
  <ul class="mt-4 list-disc space-y-1 pl-5 text-sm text-gray-600">
    <li>Editorial tag, title (1 line), description (2 lines)</li>
    <li>No ratings, views, author, or CTAs</li>
    <li>16px left / 32px right padding, ~40px bottom clearance for pagination</li>
  </ul>
</div>
