<% pagy = Pagy.new(count: 50, page: 2, limit: 10) %>

<div class="space-y-10">
  <section>
    <p class="mb-3 text-sm font-medium text-gray-500">Form buttons (Turbo frame)</p>
    <div class="rounded-xl bg-white p-8">
      <%= render Ui::PaginationComponent.new(pagy: pagy, frame_id: 'preview-frame') %>
    </div>
  </section>

  <section class="dark">
    <p class="mb-3 text-sm font-medium text-gray-400">Dark</p>
    <div class="rounded-xl bg-gray-950 p-8">
      <%= render Ui::PaginationComponent.new(pagy: pagy, frame_id: 'preview-frame') %>
    </div>
  </section>
</div>
