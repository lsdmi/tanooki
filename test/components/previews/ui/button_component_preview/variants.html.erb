<% variants = %i[primary ghost] %>
<% sizes = %i[xs md] %>

<div class="space-y-10">
  <section>
    <p class="mb-3 text-sm font-medium text-gray-500">Light</p>
    <div class="space-y-8 rounded-xl bg-white p-8">
      <% variants.each do |variant| %>
        <div>
          <h2 class="mb-4 text-lg font-semibold capitalize text-stone-800"><%= variant %></h2>
          <div class="flex flex-wrap items-center gap-3">
            <% sizes.each do |size| %>
              <%= render Ui::ButtonComponent.new(label: size.to_s.upcase, variant: variant, size: size) %>
            <% end %>
          </div>
        </div>
      <% end %>

      <div>
        <h2 class="mb-4 text-lg font-semibold text-stone-800">Icon</h2>
        <div class="flex flex-wrap items-center gap-3">
          <% variants.each do |variant| %>
            <%= render Ui::ButtonComponent.new(variant: variant, size: :icon, html: { title: variant.to_s }) do %>
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            <% end %>
          <% end %>
        </div>
      </div>

      <div>
        <h2 class="mb-4 text-lg font-semibold text-stone-800">Link &amp; states</h2>
        <div class="flex flex-wrap items-center gap-3">
          <%= render Ui::ButtonComponent.new(label: 'Посилання', as: :link, href: '#', variant: :primary) %>
          <%= render Ui::ButtonComponent.new(label: 'На всю ширину', variant: :primary, full_width: true, html: { class: 'max-w-xs' }) %>
        </div>
      </div>
    </div>
  </section>

  <section class="dark">
    <p class="mb-3 text-sm font-medium text-gray-400">Dark</p>
    <div class="space-y-8 rounded-xl bg-gray-950 p-8">
      <% variants.each do |variant| %>
        <div>
          <h2 class="mb-4 text-lg font-semibold capitalize text-gray-100"><%= variant %></h2>
          <div class="flex flex-wrap items-center gap-3">
            <% sizes.each do |size| %>
              <%= render Ui::ButtonComponent.new(label: size.to_s.upcase, variant: variant, size: size) %>
            <% end %>
          </div>
        </div>
      <% end %>

      <div>
        <h2 class="mb-4 text-lg font-semibold text-gray-100">Icon</h2>
        <div class="flex flex-wrap items-center gap-3">
          <% variants.each do |variant| %>
            <%= render Ui::ButtonComponent.new(variant: variant, size: :icon, html: { title: variant.to_s }) do %>
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            <% end %>
          <% end %>
        </div>
      </div>

      <div>
        <h2 class="mb-4 text-lg font-semibold text-gray-100">Link &amp; states</h2>
        <div class="flex flex-wrap items-center gap-3">
          <%= render Ui::ButtonComponent.new(label: 'Посилання', as: :link, href: '#', variant: :primary) %>
          <%= render Ui::ButtonComponent.new(label: 'На всю ширину', variant: :primary, full_width: true, html: { class: 'max-w-xs' }) %>
        </div>
      </div>
    </div>
  </section>
</div>
