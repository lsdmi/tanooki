# AdSense (production). Do not paste AdSense HTML into views — use these env vars only.
# Publisher id from AdSense (ca-pub-…); slot id is data-ad-slot from the unit (e.g. 9495090525).
ADSENSE_CLIENT="ca-pub-5596031369567303"
ADSENSE_CHAPTER_READER_TOP_SLOT="9495090525"
ADSENSE_CHAPTER_READER_BOTTOM_SLOT=""
ADSENSE_FICTION_ALPHABETICAL_SLOT=""
ADSENSE_BOOKSHELF_SLOT=""
ADSENSE_CHAPTER_READER_DRAWER_SLOTS=""
# Web app only: CDN host for /assets/* (not needed for DO build upload). See production.rb proc.
# ASSET_HOST=https://baka-assets.fra1.cdn.digitaloceanspaces.com
ASSET_HOST=""
DB_HOST=""
DB_NAME=""
DB_PASSWORD="somepassword"
DB_PORT=""
DB_USER=""
# DO Managed OpenSearch. Required on DO web + worker before deploy.
# Local: add your IPv4 to cluster Trusted sources; copy vars from App Platform.
# Development uses *_development indices on the same cluster (safer than prod indices).
# After first setup: rails runner "Searchkick.callbacks(:inline) { Fiction.reindex; Publication.reindex; YoutubeVideo.reindex }"
# With OPENSEARCH_URL set, development indexes inline on save (no jobs worker required for search).
# Production: weekly Searchkick::SyncSoftDeletableJob (Sunday 5:00) + manual bin/rails searchkick:sync_soft_deletable
OPENSEARCH_URL="https://HOST:25060"
OPENSEARCH_PASSWORD=""
OPENSEARCH_USER="doadmin"
OPENSEARCH_OPEN_TIMEOUT="2"
OPENSEARCH_TIMEOUT="60"
# Paste from DO cluster; keep \n line breaks (or one long line — initializer normalizes it).
# Loaded in memory for TLS verification (not written to disk).
OPENSEARCH_CA_CERT=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

MAILER_PASSWORD=""
OPENAI_API_KEY=""
SECRET_KEY_BASE=""
# Solid Queue workers: true = inside Puma (local/single VPS). Production on DO: false + bin/jobs worker.
SOLID_QUEUE_IN_PUMA="true"
STORAGE_ACCESS_KEY=""
STORAGE_BUCKET=""
STORAGE_ENDPOINT=""
STORAGE_REGION=""
STORAGE_SECRET_KEY=""
TELEGRAM_KEY=""
YOUTUBE_API_KEY=""
