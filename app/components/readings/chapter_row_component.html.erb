<% if table_row? %>
  <tr class="hover:bg-cyan-50 dark:hover:bg-rose-900/10 transition-colors duration-200">
    <th scope="row" class="whitespace-nowrap p-4 text-sm font-medium text-gray-900 dark:text-white">
      <div class="flex items-center space-x-3">
        <div class="<%= Readings::ChapterRowComponentStyles::ICON_WRAPPER_CLASSES %>">
          <svg class="<%= Readings::ChapterRowComponentStyles::ICON_CLASSES %>" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <div>
          <%= link_to chapter.display_title,
                      chapter_path(chapter),
                      class: 'hover:text-cyan-700 dark:hover:text-rose-400 transition-colors duration-200 font-medium',
                      data: { turbo: false } %>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
            Опубліковано: <%= published_at_label %>
          </p>
        </div>
      </div>
    </th>
    <td class="p-4 text-sm text-gray-500 dark:text-gray-400">
      <div class="space-y-1">
        <div class="flex items-center space-x-2">
          <svg class="<%= Readings::ChapterRowComponentStyles::STAT_ICON_CLASSES %>" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          <span class="font-medium"><%= chapter.views %></span>
          <span class="text-xs">переглядів</span>
        </div>
        <div class="flex items-center space-x-2">
          <svg class="<%= Readings::ChapterRowComponentStyles::STAT_ICON_CLASSES %>" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          <span class="font-medium"><%= chapter.comments_count %></span>
          <span class="text-xs">коментарів</span>
        </div>
      </div>
    </td>
    <td class="p-4 text-right">
      <%= render_actions %>
    </td>
  </tr>
<% else %>
  <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-4 shadow-sm hover:shadow-md transition-shadow duration-200">
    <div class="flex items-start space-x-3 mb-3">
      <div class="<%= Readings::ChapterRowComponentStyles::ICON_WRAPPER_CLASSES %> flex-shrink-0">
        <svg class="<%= Readings::ChapterRowComponentStyles::ICON_CLASSES %>" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <%= link_to chapter.display_title,
                    chapter_path(chapter),
                    class: 'block hover:text-cyan-700 dark:hover:text-rose-400 transition-colors duration-200 font-medium text-gray-900 dark:text-white',
                    data: { turbo: false } %>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
          Опубліковано: <%= published_at_label %>
        </p>
      </div>
    </div>
    <div class="flex items-center space-x-4 mb-3 text-sm">
      <div class="flex items-center space-x-1">
        <svg class="<%= Readings::ChapterRowComponentStyles::STAT_ICON_CLASSES %>" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
        <span class="font-medium text-gray-900 dark:text-white"><%= chapter.views %></span>
        <span class="text-xs text-gray-500 dark:text-gray-400">переглядів</span>
      </div>
      <div class="flex items-center space-x-1">
        <svg class="<%= Readings::ChapterRowComponentStyles::STAT_ICON_CLASSES %>" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
        <span class="font-medium text-gray-900 dark:text-white"><%= chapter.comments_count %></span>
        <span class="text-xs text-gray-500 dark:text-gray-400">коментарів</span>
      </div>
    </div>
    <div class="flex items-center justify-end pt-3 border-t border-gray-100 dark:border-gray-700">
      <%= render_actions %>
    </div>
  </div>
<% end %>
