<% if interactive? %>
  <%= link_to href, tag_attributes do %>
    <%= label %>
  <% end %>
<% else %>
  <%= content_tag(:span, tag_attributes) do %>
    <% if stat_variant? %>
      <% if variant == :stat_views %>
        <svg class="<%= icon_classes %>" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
      <% else %>
        <svg class="<%= icon_classes %>" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
      <% end %>
      <% if truncate_label? %>
        <span class="truncate tabular-nums"><%= label %></span>
      <% else %>
        <%= label %>
      <% end %>
    <% else %>
      <%= label %>
    <% end %>
  <% end %>
<% end %>
