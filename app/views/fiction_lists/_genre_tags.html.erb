<%= render Ui::TagListComponent.new(
      labels: genres.map(&:name),
      variant: :genre,
      size: :sm,
      sort_adult_first: true,
      genre_slugs: genres.to_h { |genre| [genre.name, genre.slug] },
      href_builder: ->(name) { fiction_genre_fictions_path(genres.find { |genre| genre.name == name }) },
      tag_html: turbo_drive_visit_data
    ) %>
