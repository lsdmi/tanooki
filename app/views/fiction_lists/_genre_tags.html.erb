<% genres = genres.sample(5) %>
<% genres.each_with_index do |genre, i| %>
  <%= link_to genre.name, fiction_genre_fictions_path(genre), data: { turbo: false },
    class: "inline-block no-underline shadow-sm ring-1 ring-cyan-800 dark:ring-rose-800 bg-cyan-700 dark:bg-rose-700 text-white dark:text-gray-300 px-2 py-1 lg:py-2 rounded-md text-xs md:text-sm hover:opacity-90 transition-opacity focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400 dark:focus-visible:ring-rose-400 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-gray-800 #{'hidden lg:inline-block' if i == 1}" %>
<% end %>