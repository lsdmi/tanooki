<%= turbo_frame_tag comment do %>
  <div data-controller="flowbite" class="<%= local_assigns[:drawer] ? 'space-y-4' : 'space-y-6' %>">
    <% if local_assigns[:drawer] %>
      <%= render 'comments/comment_drawer_body', comment: comment, commentable: commentable %>
    <% else %>
      <%= render 'comments/comment_body', comment: comment %>
    <% end %>
    <%= turbo_frame_tag "replies-#{comment.id}" do %>
      <% comment.replies.each do |reply| %>
        <%= render 'comments/reply', reply:, commentable: commentable, drawer: local_assigns[:drawer] %>
      <% end %>
    <% end %>
  </div>
<% end %>
