<%# locals: comment:, commentable: %>
<article class="reader-comments-drawer__card rounded-lg border border-stone-200 bg-stone-50/80 p-3 dark:border-zinc-700 dark:bg-zinc-800/60 sm:p-4">
  <div class="flex items-start gap-3">
    <%= image_tag avatar_image_url(comment.user.avatar.image),
                  alt: comment.user.avatar.blob.filename.to_s,
                  class: 'h-9 w-9 shrink-0 rounded-full object-cover sm:h-10 sm:w-10',
                  height: '40',
                  width: '40' %>

    <div class="min-w-0 flex-1">
      <div class="flex flex-col gap-1">
        <div class="flex items-start justify-between gap-2">
          <div class="min-w-0">
            <%= link_to comment.username,
                        profile_path(comment.user.sqid),
                        turbo_drive_visit_data.merge(class: 'block truncate text-sm font-semibold text-stone-900 hover:text-cyan-700 dark:text-zinc-100 dark:hover:text-rose-400') %>
            <p class="mt-0.5 text-xs text-stone-500 dark:text-zinc-400">
              <%= comment_posted_ago(comment) %>
            </p>
          </div>

          <% if current_user&.id == comment.user_id %>
            <div class="flex shrink-0 gap-1">
              <%= link_to edit_comment_path(comment), data: { turbo_stream: "" }, class: "rounded p-1 text-stone-400 hover:text-stone-600 dark:text-zinc-500 dark:hover:text-zinc-300", aria: { label: t('chapters.reader_comments_drawer.edit') } do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                </svg>
              <% end %>
              <%= link_to comment_path(comment), data: { turbo_method: :delete, turbo_stream: "" }, class: "rounded p-1 text-stone-400 hover:text-stone-600 dark:text-zinc-500 dark:hover:text-zinc-300", aria: { label: t('chapters.reader_comments_drawer.delete') } do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
              <% end %>
            </div>
          <% end %>
        </div>

        <%= render 'comments/drawer_comment_content_frame', comment: comment %>
      </div>

      <% if current_user && comment.parent_id.blank? %>
        <%= turbo_frame_tag "comment-reply-#{comment.id}", class: "mt-2" do %>
          <%= render 'comments/actions', comment: comment, commentable: commentable, drawer: true %>
        <% end %>
      <% end %>
    </div>
  </div>
</article>
