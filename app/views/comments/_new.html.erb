<div class="<%= local_assigns.fetch(:drawer, false) || (commentable.is_a?(Chapter) && immersive_comments_drawer_form?) ? 'mb-0' : 'mb-4' %>">
  <% if comment.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900 border-l-4 border-red-400 p-3 mb-4">
      <div class="flex items-center">
        <div class="flex-shrink-0 mr-2">
          <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div>
          <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
            <%= comment.errors.messages[:content].to_sentence %>
          </h3>
        </div>
      </div>
    </div>
  <% end %>

  <%= f.hidden_field :commentable_id, value: commentable.id %>
  <%= f.hidden_field :commentable_type, value: application_record_child(commentable) %>
  <%= f.hidden_field :parent_id, value: comment.parent_id if comment.parent_id.present? %>

  <% drawer_form = local_assigns.fetch(:drawer, false) || (commentable.is_a?(Chapter) && immersive_comments_drawer_form?) %>
  <% comment_field_class = if drawer_form
    "reader-comments-drawer__input w-full resize-none rounded-lg border border-stone-200 bg-white p-3 text-sm text-stone-900 placeholder-stone-400 transition-colors focus:border-cyan-700 focus:outline-none focus:ring-2 focus:ring-cyan-500/20 dark:border-zinc-600 dark:bg-zinc-800 dark:text-zinc-100 dark:placeholder-zinc-500 dark:focus:border-rose-500 dark:focus:ring-rose-500/20 #{'border-red-500 dark:border-red-700' if comment.errors[:content].any?}"
  else
    "w-full p-3 border border-stone-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-stone-400 dark:focus:ring-gray-500 focus:border-transparent transition duration-300 bg-white dark:bg-gray-800 text-stone-900 dark:text-gray-100 placeholder-stone-400 dark:placeholder-gray-500 #{'border-red-500 dark:border-red-700' if comment.errors[:content].any?}"
  end %>
  <%= f.text_area :content,
      id: drawer_form ? "comment-field-#{comment.id || 'new'}" : 'comment',
      rows: 3,
      class: comment_field_class,
      placeholder: drawer_form ? t('chapters.reader_comments_drawer.placeholder') : 'Лишіть коментар...',
      required: true %>

  <div class="mt-3 flex <%= drawer_form ? 'flex-col space-y-2' : 'flex-col sm:flex-row space-y-2 sm:space-y-0 sm:space-x-3' %> justify-end">
    <% if drawer_form %>
      <%= ui_button(as: :submit, full_width: true, size: :md) do %>
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
        </svg>
        <span><%= t('chapters.reader_comments_drawer.submit') %></span>
      <% end %>
    <% else %>
      <%= ui_button(as: :submit, label: 'Надіслати', size: :md, html: { class: 'w-full sm:w-auto' }) %>
    <% end %>

    <% if comment.new_record? && comment.parent_id.present? %>
      <%= turbo_frame_tag "cancel-reply-#{comment.id}" do %>
        <%= ui_button(as: :link,
                      href: cancel_reply_comment_path(comment.parent_id),
                      variant: :ghost,
                      size: :md,
                      full_width: drawer_form,
                      html: { class: (drawer_form ? nil : 'w-full sm:w-auto'), data: { turbo_stream: '' } }) do %>
          <span>Скасувати</span>
        <% end %>
      <% end %>
    <% end %>

    <% if comment.persisted? %>
      <%= turbo_frame_tag "cancel-edit-comment-#{comment.id}" do %>
        <%= ui_button(as: :link,
                      href: cancel_edit_comment_path(comment),
                      variant: :ghost,
                      size: :md,
                      full_width: drawer_form,
                      html: { class: (drawer_form ? nil : 'w-full sm:w-auto'), data: { turbo_stream: '' } }) do %>
          <span>Скасувати</span>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
