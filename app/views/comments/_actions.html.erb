<% drawer_reply = local_assigns.fetch(:drawer, immersive_comments_drawer_form?) %>
<% reply_class = if drawer_reply
  'inline-flex items-center gap-1.5 text-xs font-medium text-stone-500 transition-colors hover:text-cyan-700 dark:text-zinc-400 dark:hover:text-rose-400'
else
  'text-stone-500 dark:text-gray-400 text-xs sm:text-sm hover:text-stone-700 dark:hover:text-gray-300 transition duration-300 flex items-center space-x-1 bg-stone-100 dark:bg-gray-800 px-2 sm:px-3 py-1 rounded-full hover:bg-stone-200 dark:hover:bg-gray-700'
end %>
<%= button_to new_comment_path,
    params: { comment: { parent_id: comment.id, commentable_id: commentable.id, commentable_type: application_record_child(commentable) } },
    method: :get,
    class: reply_class,
    data: { turbo_stream: "" } do %>
  <svg xmlns="http://www.w3.org/2000/svg" class="<%= drawer_reply ? 'h-3.5 w-3.5 shrink-0' : 'h-3 w-3 sm:h-4 sm:w-4' %>" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
    <path fill-rule="evenodd" d="M7.707 3.293a1 1 0 010 1.414L5.414 7H11a7 7 0 017 7v2a1 1 0 11-2 0v-2a5 5 0 00-5-5H5.414l2.293 2.293a1 1 0 11-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
  </svg>
  <span><%= t('chapters.reader_comments_drawer.reply') %></span>
<% end %>
