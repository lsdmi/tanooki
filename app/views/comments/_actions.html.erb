<% reply_href = new_comment_path(comment: { parent_id: comment.id, commentable_id: commentable.id, commentable_type: application_record_child(commentable) }) %>
<%= ui_button(as: :link,
              href: reply_href,
              variant: :ghost,
              size: :xs,
              html: { data: { turbo_stream: '' } }) do %>
  <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
    <path fill-rule="evenodd" d="M7.707 3.293a1 1 0 010 1.414L5.414 7H11a7 7 0 017 7v2a1 1 0 11-2 0v-2a5 5 0 00-5-5H5.414l2.293 2.293a1 1 0 11-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
  </svg>
  <span><%= t('chapters.reader_comments_drawer.reply') %></span>
<% end %>
