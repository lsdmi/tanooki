<%# locals: (request:, compact: false, wrapper_class: nil) %>
<%
  compact = local_assigns.fetch(:compact, false)
  text_size = compact ? 'text-xs' : 'text-sm'
  heading_size = compact ? 'text-sm' : 'text-lg'
  icon_size = compact ? 'w-3 h-3' : 'w-4 h-4'
  vote_icon_size = compact ? 'w-2.5 h-2.5' : 'w-4 h-4'
  status_icon_outer = compact ? 'h-3 w-3' : 'h-4 w-4'
  status_icon_inner = compact ? 'h-1.5 w-1.5' : 'h-2 w-2'
  vote_btn_padding = compact ? 'px-1.5 py-0.5' : 'px-3 py-1.5'
  vote_btn_text = compact ? 'text-xs' : 'text-sm'
  voted_classes = "vote-btn flex items-center gap-#{compact ? '1' : '2'} #{vote_btn_padding} rounded #{vote_btn_text} transition-colors duration-200 bg-cyan-100 text-cyan-800 dark:bg-rose-900/40 dark:text-rose-300"
  default_classes = "vote-btn flex items-center gap-#{compact ? '1' : '2'} #{vote_btn_padding} rounded #{vote_btn_text} transition-colors duration-200 text-gray-600 hover:bg-cyan-50 hover:text-cyan-800 dark:text-gray-300 dark:hover:bg-rose-900/20 dark:hover:text-rose-300"
%>
<div id="request-card-<%= request.id %>"
     <% if local_assigns[:wrapper_class].present? %> class="<%= wrapper_class %>" <% end %>
     data-controller="translation-request-card"
     data-translation-request-card-request-id-value="<%= request.id %>"
     data-translation-request-card-voted-value="<%= user_signed_in? && request.user_voted?(current_user) %>">
  <div data-translation-request-card-target="viewMode">
    <div class="<%= compact ? 'mb-2' : 'mb-3' %>">
      <div class="flex items-start justify-between">
        <h4 class="<%= heading_size %> font-semibold text-gray-800 dark:text-gray-200 <%= compact ? 'mb-1.5' : 'mb-2' %> leading-tight flex-1"
            data-translation-request-card-target="title"><%= request.title %></h4>
        <% if user_signed_in? && current_user == request.user %>
          <div class="flex items-center gap-<%= compact ? '1' : '2' %> ml-<%= compact ? '2' : '3' %> flex-shrink-0">
            <button type="button"
                    data-action="translation-request-card#toggleEdit"
                    class="<%= text_size %> text-gray-600 dark:text-gray-300 hover:text-cyan-800 dark:hover:text-rose-200 transition-colors duration-200"
                    title="Редагувати">
              <svg class="<%= icon_size %>" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
            </button>
            <button type="button"
                    data-action="translation-request-card#delete"
                    class="<%= text_size %> text-gray-600 dark:text-gray-300 hover:text-red-700 dark:hover:text-red-300 transition-colors duration-200"
                    title="Видалити">
              <svg class="<%= icon_size %>" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
            </button>
          </div>
        <% end %>
      </div>

      <div class="space-y-<%= compact ? '0.5' : '1' %> <%= compact ? 'mb-1.5' : 'mb-2' %>">
        <div class="<%= text_size %> <%= request.author.present? ? '' : 'hidden' %>"
             data-translation-request-card-target="authorRow">
          <span class="text-gray-600 dark:text-gray-400">Автор:</span>
          <span class="font-medium text-gray-700 dark:text-gray-300"
                data-translation-request-card-target="authorValue"><%= request.author %></span>
        </div>
        <div class="<%= text_size %> <%= request.source_url.present? ? '' : 'hidden' %>"
             data-translation-request-card-target="sourceRow">
          <span class="text-gray-600 dark:text-gray-400">Джерело:</span>
          <%= link_to "Переглянути", request.source_url,
              class: "text-cyan-800 dark:text-rose-300 hover:text-cyan-950 dark:hover:text-rose-200 hover:underline font-medium",
              target: "_blank", rel: "noopener noreferrer",
              data: { translation_request_card_target: 'sourceLink' } %>
        </div>
      </div>
    </div>
    <p class="<%= text_size %> text-gray-600 dark:text-gray-400 <%= compact ? 'mb-2' : 'mb-3' %> whitespace-pre-line"
       data-translation-request-card-target="notes"><%= request.notes %></p>

    <div class="flex items-center justify-between pt-<%= compact ? '2' : '3' %> border-t border-gray-200 dark:border-gray-600">
      <div class="flex items-center gap-<%= compact ? '2' : '3' %>">
        <% if user_signed_in? %>
          <button type="button"
                  data-action="translation-request-card#vote"
                  data-translation-request-card-target="voteButton"
                  data-voted-class="<%= voted_classes %>"
                  data-default-class="<%= default_classes %>"
                  class="<%= request.user_voted?(current_user) ? voted_classes : default_classes %>">
            <svg class="<%= vote_icon_size %>" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M3.293 9.707a1 1 0 010-1.414l6-6a1 1 0 011.414 0l6 6a1 1 0 01-1.414 1.414L11 5.414V17a1 1 0 11-2 0V5.414L4.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
            <span data-translation-request-card-target="upvoteCount"><%= request.votes_count %></span>
          </button>
          <div class="<%= text_size %> font-medium text-gray-600 dark:text-gray-400">
            <span data-translation-request-card-target="votesCount"><%= request.votes_count %></span> голосів
          </div>
        <% else %>
          <div class="flex items-center gap-<%= compact ? '2' : '3' %>">
            <div class="flex items-center gap-<%= compact ? '1' : '2' %> <%= text_size %> text-gray-500 dark:text-gray-400">
              <svg class="<%= vote_icon_size %>" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M3.293 9.707a1 1 0 010-1.414l6-6a1 1 0 011.414 0l6 6a1 1 0 01-1.414 1.414L11 5.414V17a1 1 0 11-2 0V5.414L4.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd" />
              </svg>
              <span><%= request.votes_count %></span>
            </div>
            <div class="<%= text_size %> font-medium text-gray-600 dark:text-gray-400">
              <span data-translation-request-card-target="votesCount"><%= request.votes_count %></span> голосів
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="mt-<%= compact ? '2' : '3' %> pt-<%= compact ? '2' : '3' %> border-t border-gray-200 dark:border-gray-600">
      <div data-translation-request-card-target="assignmentAssigned" class="<%= request.assigned? ? '' : 'hidden' %>">
        <div class="flex items-center justify-between gap-<%= compact ? '1' : '2' %>">
          <div class="flex items-center gap-<%= compact ? '1' : '2' %> min-w-0 flex-1">
            <div class="<%= status_icon_outer %> rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center flex-shrink-0">
              <svg class="<%= status_icon_inner %> text-green-600 dark:text-green-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
            <span class="<%= text_size %> font-medium text-green-700 dark:text-green-400 truncate"
                  data-translation-request-card-target="scanlatorTitle"><%= request.scanlator&.title %></span>
          </div>
          <% if user_signed_in? && request.scanlator && current_user.scanlators.include?(request.scanlator) %>
            <button type="button"
                    data-action="translation-request-card#unassign"
                    class="<%= text_size %> bg-red-500 hover:bg-red-600 text-white font-medium px-<%= compact ? '2' : '3' %> py-0.5 rounded text-center flex-shrink-0 transition-colors duration-200">
              ×
            </button>
          <% end %>
        </div>
      </div>

      <div data-translation-request-card-target="assignmentAvailable" class="<%= request.assigned? ? 'hidden' : '' %>">
        <% if user_signed_in? && current_user.scanlators.any? %>
          <div class="flex items-center justify-between gap-<%= compact ? '1' : '2' %>">
            <div class="flex items-center gap-<%= compact ? '1' : '2' %> min-w-0 flex-1">
              <div class="<%= status_icon_outer %> rounded-full bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center flex-shrink-0">
                <svg class="<%= status_icon_inner %> text-orange-600 dark:text-orange-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v3.586L7.707 9.293a1 1 0 00-1.414 1.414l3 3a1 1 0 001.414 0l3-3a1 1 0 00-1.414-1.414L11 10.586V7z" clip-rule="evenodd" />
                </svg>
              </div>
              <span class="<%= text_size %> text-orange-700 dark:text-orange-400">Вільний</span>
            </div>
            <div class="relative flex-shrink-0" data-translation-request-card-dropdown>
              <%= ui_button(as: :button, size: compact ? :xs : :xs, html: {
                    class: 'assign-btn',
                    type: 'button',
                    data: { action: 'translation-request-card#toggleAssignmentDropdown' }
                  }) do %>
                +
                <svg class="<%= compact ? 'w-2 h-2' : 'w-3 h-3' %>" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              <% end %>
              <div data-translation-request-card-target="assignmentDropdown"
                   class="hidden absolute right-0 mt-1 w-40 bg-white dark:bg-gray-800 rounded shadow-lg z-10 border border-gray-200 dark:border-gray-600">
                <div class="py-1">
                  <% current_user.scanlators.each do |scanlator| %>
                    <button type="button"
                            data-action="translation-request-card#assign"
                            data-translation-request-card-scanlator-id-param="<%= scanlator.id %>"
                            class="block w-full text-left px-3 py-1.5 <%= text_size %> text-gray-800 dark:text-gray-200 hover:bg-cyan-50 dark:hover:bg-rose-900/20 hover:text-cyan-900 dark:hover:text-rose-200 transition-colors duration-200 truncate">
                      <%= scanlator.title %>
                    </button>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% else %>
          <div class="flex items-center gap-<%= compact ? '1' : '2' %>">
            <div class="<%= status_icon_outer %> rounded-full bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center flex-shrink-0">
              <svg class="<%= status_icon_inner %> text-orange-600 dark:text-orange-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v3.586L7.707 9.293a1 1 0 00-1.414 1.414l3 3a1 1 0 001.414 0l3-3a1 1 0 00-1.414-1.414L11 10.586V7z" clip-rule="evenodd" />
              </svg>
            </div>
            <span class="<%= text_size %> text-orange-700 dark:text-orange-400">Вільний</span>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex justify-between items-center <%= text_size %> pt-<%= compact ? '1.5' : '2' %> border-t border-gray-200 dark:border-gray-600 mt-<%= compact ? '1.5' : '3' %>">
      <span class="text-gray-600 dark:text-gray-400 truncate mr-2">
        <%= link_to request.user.name, profile_path(request.user.sqid),
            class: "font-medium text-cyan-800 dark:text-rose-300 hover:text-cyan-950 dark:hover:text-rose-200 hover:underline" %>
      </span>
      <span class="text-gray-600 dark:text-gray-400 flex-shrink-0">
        <%= time_ago_in_words(request.created_at) %> тому
      </span>
    </div>
  </div>

  <% if user_signed_in? && current_user == request.user %>
    <div data-translation-request-card-target="editMode" class="hidden">
      <form class="space-y-<%= compact ? '3' : '4' %>">
        <div>
          <label class="block <%= text_size %> font-medium text-gray-700 dark:text-gray-300 mb-1">Назва проекту</label>
          <input type="text"
                 autocomplete="off"
                 value="<%= request.title %>"
                 data-translation-request-card-field="title"
                 class="w-full <%= text_size %> bg-gray-100 dark:bg-gray-600 text-gray-800 dark:text-gray-200 border border-gray-300 dark:border-gray-500 rounded p-2 focus:ring-1 focus:ring-cyan-500 focus:border-cyan-500">
        </div>
        <div>
          <label class="block <%= text_size %> font-medium text-gray-700 dark:text-gray-300 mb-1">Автор оригіналу</label>
          <input type="text"
                 autocomplete="off"
                 value="<%= request.author %>"
                 data-translation-request-card-field="author"
                 class="w-full <%= text_size %> bg-gray-100 dark:bg-gray-600 text-gray-800 dark:text-gray-200 border border-gray-300 dark:border-gray-500 rounded p-2 focus:ring-1 focus:ring-cyan-500 focus:border-cyan-500">
        </div>
        <div>
          <label class="block <%= text_size %> font-medium text-gray-700 dark:text-gray-300 mb-1">Посилання на оригінал</label>
          <input type="url"
                 autocomplete="off"
                 value="<%= request.source_url %>"
                 data-translation-request-card-field="sourceUrl"
                 class="w-full <%= text_size %> bg-gray-100 dark:bg-gray-600 text-gray-800 dark:text-gray-200 border border-gray-300 dark:border-gray-500 rounded p-2 focus:ring-1 focus:ring-cyan-500 focus:border-cyan-500">
        </div>
        <div>
          <label class="block <%= text_size %> font-medium text-gray-700 dark:text-gray-300 mb-1">Опис проекту та деталі</label>
          <textarea rows="<%= compact ? 3 : 4 %>"
                    data-translation-request-card-field="notes"
                    class="w-full <%= text_size %> bg-gray-100 dark:bg-gray-600 text-gray-800 dark:text-gray-200 border border-gray-300 dark:border-gray-500 rounded p-2 focus:ring-1 focus:ring-cyan-500 focus:border-cyan-500 whitespace-pre-line"><%= request.notes %></textarea>
        </div>
        <div class="flex justify-end gap-2 pt-2">
          <button type="button"
                  data-action="translation-request-card#cancelEdit"
                  class="<%= text_size %> bg-gray-500 hover:bg-gray-600 text-white font-medium px-<%= compact ? '3' : '4' %> py-<%= compact ? '1' : '2' %> rounded transition-colors duration-200">
            Скасувати
          </button>
          <%= ui_button(as: :button, size: compact ? :xs : :md, label: 'Зберегти', html: {
                type: 'button',
                data: { action: 'translation-request-card#saveEdit' }
              }) %>
        </div>
      </form>
    </div>
  <% end %>
</div>
