<div class="relative z-10 flex w-full max-w-7xl justify-center px-4">
  <div class="relative w-full max-w-lg overflow-hidden rounded-2xl border border-stone-200 bg-white/80 p-10 text-center shadow-xl backdrop-blur-xl dark:border-gray-700 dark:bg-gray-800/85">
    <div class="pointer-events-none absolute inset-0 z-0 text-stone-500 opacity-[0.07] dark:text-gray-400">
      <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-32 w-full" fill="none" viewBox="0 0 120 80" aria-hidden="true">
        <rect x="8" y="12" width="104" height="56" rx="6" stroke="currentColor" stroke-width="1.5" />
        <path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" d="M8 28h104M32 12v56" />
        <circle cx="92" cy="48" r="8" stroke="currentColor" stroke-width="1.5" />
      </svg>
    </div>
    <% catalog_link = link_to t('chapters_calendar.empty_catalog_link'), '/fictions',
                                class: 'font-semibold text-stone-800 underline underline-offset-2 hover:text-stone-600 dark:text-gray-100 dark:hover:text-rose-400',
                                data: { turbo_frame: '_top' } %>
    <% if subscriptions_filter_active %>
      <p class="relative z-10 mb-3 text-lg font-semibold text-stone-800 dark:text-gray-100">
        <%= t('chapters_calendar.empty_subscriptions') %>
      </p>
      <p class="relative z-10 text-sm leading-relaxed text-stone-500 dark:text-gray-400">
        <%= t('chapters_calendar.empty_hint_subscriptions', catalog_link: catalog_link).html_safe %>
      </p>
    <% else %>
      <p class="relative z-10 text-base leading-relaxed text-stone-600 dark:text-gray-300">
        <%= t('chapters_calendar.empty_updates', catalog_link: catalog_link).html_safe %>
      </p>
    <% end %>
  </div>
</div>
