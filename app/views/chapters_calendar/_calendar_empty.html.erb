<div class="w-full max-w-7xl relative z-10 flex justify-center px-4">
  <div class="w-full max-w-lg border border-stone-200 dark:border-stone-700 bg-white/80 dark:bg-stone-800/80 backdrop-blur-xl rounded-2xl shadow-xl p-10 text-center relative overflow-hidden">
    <div class="absolute inset-0 z-0 opacity-[0.07] text-stone-500 dark:text-stone-400 pointer-events-none">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-full h-32 mx-auto" fill="none" viewBox="0 0 120 80" aria-hidden="true">
        <rect x="8" y="12" width="104" height="56" rx="6" stroke="currentColor" stroke-width="1.5"/>
        <path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" d="M8 28h104M32 12v56"/>
        <circle cx="92" cy="48" r="8" stroke="currentColor" stroke-width="1.5"/>
      </svg>
    </div>
    <% catalog_link = link_to t('chapters_calendar.empty_catalog_link'), '/fictions',
                                class: 'font-semibold text-stone-800 dark:text-stone-100 underline underline-offset-2 hover:text-stone-600 dark:hover:text-stone-300',
                                data: { turbo_frame: '_top' } %>
    <% if @subscriptions_filter_active %>
      <p class="relative z-10 text-lg font-semibold text-stone-800 dark:text-stone-100 mb-3">
        <%= t('chapters_calendar.empty_subscriptions') %>
      </p>
      <p class="relative z-10 text-sm text-stone-500 dark:text-stone-400 leading-relaxed">
        <%= t('chapters_calendar.empty_hint_subscriptions', catalog_link: catalog_link).html_safe %>
      </p>
    <% else %>
      <p class="relative z-10 text-base text-stone-600 dark:text-stone-300 leading-relaxed">
        <%= t('chapters_calendar.empty_updates', catalog_link: catalog_link).html_safe %>
      </p>
    <% end %>
  </div>
</div>
