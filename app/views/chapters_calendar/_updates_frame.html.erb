<% if user_signed_in? %>
  <% all_active = !subscriptions_filter_active %>
  <% subs_active = subscriptions_filter_active %>
  <div class="mb-8 flex justify-center">
    <% segmented = "inline-flex rounded-xl border border-stone-200 bg-white/70 p-1 shadow-sm backdrop-blur-sm dark:border-gray-700 dark:bg-gray-800/80" %>
    <div class="<%= segmented %>" role="group" aria-label="<%= t('chapters_calendar.all_updates') %> / <%= t('chapters_calendar.my_subscriptions') %>">
      <%= form_with url: calendar_fictions_path, method: :get, local: true,
                    data: { turbo_stream: "" },
                    html: { class: "inline m-0 align-middle" } do %>
        <button type="submit"
                class="rounded-lg px-4 py-2 text-sm font-semibold transition-colors duration-200 <%= all_active ? 'bg-stone-800 text-stone-50 shadow dark:bg-gray-700 dark:text-white' : 'text-stone-600 hover:text-stone-800 dark:text-gray-400 dark:hover:text-gray-200' %>">
          <%= t('chapters_calendar.all_updates') %>
        </button>
      <% end %>
      <%= form_with url: calendar_fictions_path, method: :get, local: true,
                    data: { turbo_stream: "" },
                    html: { class: "inline m-0 align-middle" } do %>
        <%= hidden_field_tag :subscriptions, true %>
        <button type="submit"
                class="rounded-lg px-4 py-2 text-sm font-semibold transition-colors duration-200 <%= subs_active ? 'bg-stone-800 text-stone-50 shadow dark:bg-gray-700 dark:text-white' : 'text-stone-600 hover:text-stone-800 dark:text-gray-400 dark:hover:text-gray-200' %>">
          <%= t('chapters_calendar.my_subscriptions') %>
        </button>
      <% end %>
    </div>
  </div>
<% end %>
<%= render "chapters_calendar/calendar_grid",
           fictions: fictions,
           subscriptions_filter_active: subscriptions_filter_active %>
