<div class="grid mb-1 mt-2 lg:mb-0 lg:mt-0 lg:gap-8 lg:divide-x-4 lg:divide-purple-200 lg:grid-cols-3">
  <div class="lg:col-span-2">
    <% publications[0..7]&.each do |highlight| %>
      <article class="mt-2 lg:mt-0 mb-1 lg:mb-2 flex flex-col md:flex-row lg:flex-col md:gap-4 md:items-start">
        <div class="relative w-full md:w-2/5 lg:w-full shrink-0 overflow-hidden rounded-md h-48 md:h-44 lg:h-48">
          <%= link_to tale_path(highlight), class: "block h-full w-full" do %>
            <%= image_tag cover_card_url(highlight.cover), alt: highlight.cover.blob.filename.to_s, class: "h-full w-full object-cover rounded-md opacity-80", width: 320, height: 192 %>
            <div class="absolute inset-0 rounded-md opacity-0 hover:opacity-100 transition duration-300 ease-in-out" style="background-color: rgba(255, 255, 255, 0.2)"></div>
          <% end %>
        </div>
        <div class="w-full md:flex-1 md:min-w-0">
          <div class="rounded-xl mb-1 text-gray-500 dark:text-gray-400">
            <div class="sm:mb-1 lg:mb-0">
              <%= render Ui::TagListComponent.new(
                    labels: highlight.tags.map(&:name),
                    variant: :keyword,
                    size: :sm,
                    max: 3,
                    href_builder: ->(name) { search_index_path(search: [name]) },
                    counts: publication_tag_counts
                  ) %>
            </div>
            <h2 class="mt-2 mb-1 text-2xl lg:text-xl font-bold tracking-tight text-gray-900 dark:text-gray-100 hover:underline line-clamp-3">
              <%= link_to highlight.title, tale_path(highlight) %>
            </h2>
            <%= tag.p highlight.description.to_plain_text, class: 'text-base lg:text-sm font-light text-gray-500 dark:text-gray-400 line-clamp-2 md:line-clamp-3 mt-2 lg:mt-1 lg:leading-6' %>
          </div>
        </div>
      </article>
    <% end %>
  </div>
  <div class="lg:space-y-8 lg:pl-8">
    <% publications[8...17]&.each do |tale| %>
      <article class="mt-2 lg:mt-0 flex flex-col md:flex-row lg:flex-col md:gap-4 md:items-start">
        <div class="relative w-full md:w-2/5 shrink-0 overflow-hidden rounded-md h-48 md:h-48 lg:hidden">
          <%= link_to tale_path(tale), class: "block h-full w-full lg:hidden" do %>
            <%= image_tag cover_card_url(tale.cover), alt: tale.cover.blob.filename.to_s, class: "h-full w-full object-cover rounded-lg" %>
            <div class="absolute inset-0 rounded-xl opacity-0 hover:opacity-100 transition duration-300 ease-in-out" style="background-color: rgba(255, 255, 255, 0.2)"></div>
          <% end %>
        </div>
        <div class="w-full md:flex-1 md:min-w-0 lg:mb-4">
          <%= render Ui::TagListComponent.new(
                labels: tale.tags.map(&:name),
                variant: :keyword,
                size: :sm,
                max: 3,
                href_builder: ->(name) { search_index_path(search: [name]) },
                counts: publication_tag_counts
              ) %>
          <h2 class="mt-2 text-2xl lg:text-xl font-bold tracking-tight text-gray-900 dark:text-gray-100 hover:underline">
            <%= link_to tale.title, tale_path(tale) %>
          </h2>
          <%= tag.p tale.description.to_plain_text, class: 'mb-4 mt-2 text-base lg:text-sm font-light text-gray-500 dark:text-gray-400 line-clamp-2 md:line-clamp-3' %>
        </div>
      </article>
    <% end %>
  </div>
</div>
