<% page_gutter = 'mx-5 md:mx-6 lg:mx-8 xl:mx-0' %>

<section class="relative z-10 mx-auto xl:w-[1300px]">
  <div class="<%= page_gutter %> mt-8 overflow-hidden rounded-xl border border-gray-200 shadow-md lg:mt-10 lg:rounded-2xl dark:border-gray-700">
    <%= render 'root/hero' %>
  </div>

  <div class="<%= page_gutter %>">
    <div class="mb-8 mt-8 lg:mb-14 lg:mt-14">
      <header class="mb-8 flex items-stretch gap-3 sm:gap-4">
        <div class="w-1.5 shrink-0 rounded-lg bg-cyan-700 dark:bg-rose-500" aria-hidden="true"></div>
        <div class="flex min-w-0 flex-1 items-center justify-between gap-4">
          <h2 class="text-2xl font-bold leading-snug tracking-tight text-stone-900 dark:text-slate-100">
            Популярне <span class="text-cyan-700 dark:text-rose-400">ранобе</span>
          </h2>
          <%= link_to fictions_path, class: 'inline-flex shrink-0 items-baseline gap-0.5 text-md font-medium leading-snug text-cyan-700 transition duration-300 hover:underline dark:text-rose-400' do %>
            <span class="hidden sm:inline">Більше</span>
            <span aria-hidden="true">&rsaquo;</span>
          <% end %>
        </div>
      </header>

      <%= render 'root/fictions', fictions: @top_fictions.limit(10) %>
    </div>

    <div class="my-4 border border-gray-200 dark:border-gray-700 rounded-md shadow-md">
      <%= render 'shared/ads', advertisement: @advertisement %>
    </div>

    <div class="mb-4 flex">
      <div class="mr-2 shrink-0 hidden sm:flex flex-col justify-center">
        <%= image_tag 'youtube.webp', class: 'h-20 inline-block transform transition duration-500 hover:scale-110', alt: 'youtube icon', width: '80', height: '80' %>
      </div>
      <div class="flex flex-col justify-center sm:ml-0">
        <p class="uppercase leading-5 text-stone-900 dark:text-gray-100 text-2xl sm:text-4xl font-extrabold tracking-tight">
          Краще на <span class="text-cyan-700 dark:text-rose-700">YouTube</span>
        </p>
      </div>
    </div>

    <div class="mb-4 sm:mb-6 md:mb-8">
      <%= render 'root/videos', videos: @videos, video_tag_counts: @video_tag_counts %>
    </div>

    <% if @pokemon_ad.present? %>
      <div class="my-4 border border-gray-200 dark:border-gray-700 rounded-md shadow-md">
        <%= render 'shared/ads', advertisement: @pokemon_ad %>
      </div>
    <% end %>

    <%= render 'root/tales', tales: @tales, top_tales: @top_tales %>
  </div>
</section>
