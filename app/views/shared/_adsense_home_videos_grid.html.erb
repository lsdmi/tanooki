<%# Dual promo row below homepage «Популярні Відео»: Telegram + Buy Me a Coffee. %>
<% mobile_slot_margins = ['', 'mt-3'] %>

<section class="home-videos-ads mt-8 mb-14 md:mt-14 sm:mb-0" aria-label="Підтримка">
  <div class="flex flex-col sm:grid sm:grid-cols-2 sm:items-stretch sm:gap-x-[28px] sm:gap-y-8">
    <% home_videos_grid_promos.each_with_index do |promo, index| %>
      <div class="home-videos-ads__slot flex h-full <%= mobile_slot_margins[index] %> sm:mt-0">
        <%= render 'root/prefooter/promo_card', **home_videos_grid_promo_card(promo) %>
      </div>
    <% end %>
  </div>
</section>
