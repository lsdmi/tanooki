<%# locals: (name:, url:, wrapper_class: nil, link_class: nil, as_tag: false) %>
<p class="author flex flex-wrap items-center gap-x-2 gap-y-1 text-sm <%= wrapper_class %>">
  <span class="font-bold text-stone-800 dark:text-gray-200">Автор:</span>
  <% if as_tag %>
    <%= render Ui::TagComponent.new(
          label: name,
          variant: :keyword,
          size: :sm,
          as: :link,
          href: url,
          html: { rel: 'author' }
        ) %>
  <% else %>
    <%= link_to name, url, rel: 'author', class: link_class %>
  <% end %>
</p>
