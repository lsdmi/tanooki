<footer class="bg-gray-900 border-t border-gray-200 dark:border-gray-700">
  <div class="p-4 py-6 mx-auto max-w-screen-2xl md:p-8 lg:-10">
    <div class="grid grid-cols-2 gap-8 lg:grid-cols-6">
      <div class="col-span-2">
        <a href="/" class="flex items-center mb-2 text-2xl font-semibold sm:mb-0 text-white">
          <%= image_tag 'logo-dark.svg', class: 'h-14 lg:h-28 transition duration-500 hover:scale-110', alt: 'logo', width: '192', height: '64' %>
        </a>
        <p class="my-4 font-light text-gray-400">baka.in.ua - українська аніме-платформа, де зібрано сотні блогів, статей, ранобе та веб-новел, а також відео вітчизняних ютуберів!</p>
      </div>
      <% trending_tags.in_groups_of(4).each_with_index do |group, index| %>
        <div class="lg:mx-auto">
          <%= tag.h2 index.zero? ? 'Популярні теґи' : '', class: 'mb-6 text-sm font-semibold uppercase text-white min-h-5' %>
          <ul class="text-gray-400">
            <% group.each do |trending_tag| %>
              <li class="mb-4">
                <%= link_to trending_tag[:name], trending_tag[:link], class: "hover:underline" if trending_tag.present? %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
    <hr class="my-6 sm:mx-auto border-gray-700 lg:my-8">
    <div class="flex flex-col items-center gap-6 text-sm text-gray-400 lg:flex-row lg:items-start lg:justify-between">
      <p class="text-center lg:mb-0 lg:max-w-md lg:text-left">
        © 2023-<%= Time.zone.now.year %>
        <a href="/" class="hover:underline">baka.in.ua™</a>.
        Всі права захищені.
      </p>
      <nav class="mx-auto grid w-fit grid-cols-3 gap-x-6 gap-y-3 justify-items-center text-center lg:ml-auto lg:mr-0 lg:justify-items-start lg:text-left" aria-label="Юридична інформація та контакти">
        <%= link_to about_path, class: 'hover:underline underline-offset-2 block whitespace-nowrap', title: 'Про Баку — baka.in.ua' do %>
          Про Бака
        <% end %>
        <%= link_to privacy_path, class: 'hover:underline underline-offset-2 block whitespace-nowrap', title: 'Політика конфіденційності — baka.in.ua' do %>
          Конфіденційність
        <% end %>
        <%= link_to privacy_path(anchor: 'cookies'), class: 'hover:underline underline-offset-2 block whitespace-nowrap', title: 'Політика cookies — baka.in.ua' do %>
          Cookies
        <% end %>
        <%= link_to rules_path, class: 'col-start-2 hover:underline underline-offset-2 block whitespace-nowrap lg:col-start-auto', title: 'Правила спільноти — baka.in.ua' do %>
          Правила
        <% end %>
        <%= link_to 'https://t.me/bakaInUa', class: 'hover:underline underline-offset-2 block whitespace-nowrap', title: 'Контакти (Telegram) — baka.in.ua', rel: 'noopener noreferrer', target: '_blank' do %>
          Контакти
        <% end %>
      </nav>
    </div>
  </div>
</footer>
