<nav class="py-4 bg-white dark:bg-gray-900 antialiased relative z-50 shadow-md border-b border-gray-200 dark:border-gray-700">
  <div class="max-w-screen-xl px-4 mx-auto 2xl:px-0">
    <div class="flex flex-wrap items-center justify-between gap-4 md:flex-nowrap">
      <% cache navbar_fragment_cache_key(:brand), expires_in: 1.hour do %>
        <%= render "shared/navbar_brand" %>
      <% end %>

      <div class="flex items-center justify-end md:space-x-2 md:order-3 md:mt-0 mt-1">
        <% cache navbar_fragment_cache_key(:toolbar), expires_in: 1.hour do %>
          <%= render "shared/navbar_toolbar" %>
        <% end %>
        <%= render "shared/navbar_auth" %>
      </div>

      <% cache navbar_fragment_cache_key(:nav_links), expires_in: 1.hour do %>
        <%= render "shared/navbar_nav_links" %>
      <% end %>
    </div>
  </div>
</nav>

<% cache navbar_fragment_cache_key(:search_modal), expires_in: 1.hour do %>
  <%= render "shared/navbar_search_modal" %>
<% end %>
