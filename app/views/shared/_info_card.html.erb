<%# locals: (content:, title: nil, icon: false) %>
<section class="bg-gradient-to-br from-stone-50 to-stone-100 dark:from-gray-800 dark:to-gray-700 rounded-lg shadow-md p-4 sm:p-6 md:p-8 border border-stone-200 dark:border-gray-700 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-24 sm:w-32 h-24 sm:h-32 bg-stone-200 dark:bg-gray-600 rounded-full transform translate-x-1/2 -translate-y-1/2 opacity-30"></div>

  <% if title.present? %>
    <div class="flex items-center pb-4 relative z-10">
      <% if icon %>
        <svg class="w-6 h-6 sm:w-8 sm:h-8 text-stone-600 dark:text-gray-300 mr-2 sm:mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
        </svg>
      <% end %>
      <h4 class="text-xl sm:text-2xl font-bold text-stone-800 dark:text-gray-200"><%= title %></h4>
    </div>
  <% end %>

  <div class="relative z-10">
    <%= content %>
  </div>

  <div class="absolute bottom-0 left-0 w-20 sm:w-24 h-20 sm:h-24 bg-stone-200 dark:bg-gray-600 rounded-full transform -translate-x-1/2 translate-y-1/2 opacity-30"></div>
</section>
