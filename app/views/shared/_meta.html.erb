<%= tag.title meta_title %>

<%= tag.link rel: 'canonical', href: canonical_url %>

<%= tag.meta name: 'viewport', content: 'width=device-width,initial-scale=1' %>
<%= tag.meta name: 'description', content: meta_description %>
<%= tag.meta name: 'robots', content: 'max-image-preview:large' %>

<%= tag.meta property: 'og:title', content: meta_title %>
<%= tag.meta property: 'og:site_name', content: 'Бака' %>
<%= tag.meta property: 'og:description', content: meta_description %>
<%= tag.meta property: 'og:image', content: meta_image %>
<%= tag.meta property: 'og:image:width', content: '1400' %>
<%= tag.meta property: 'og:image:height', content: '700' %>
<%= tag.meta property: 'og:locale', content: 'uk_UA' %>
<%= tag.meta property: 'og:type', content: meta_type %>
<%= tag.meta property: 'og:url', content: canonical_url %>

<% if article_author_meta?(publication) %>
  <%= tag.meta name: 'author', content: publication.username %>
  <%= tag.meta property: 'article:author', content: publication_author_profile_url(publication) %>
  <%= tag.meta property: 'article:published_time', content: publication.created_at.iso8601 %>
  <%= tag.meta property: 'article:modified_time', content: publication.updated_at.iso8601 %>
<% elsif chapter_reader_meta? && chapter %>
  <%= tag.meta name: 'author', content: chapter.fiction.author %>
  <%= tag.meta property: 'article:published_time', content: (chapter.published_at || chapter.created_at).iso8601 %>
  <%= tag.meta property: 'article:modified_time', content: chapter.updated_at.iso8601 %>
<% end %>

<%= tag.meta name: 'twitter:card', content: 'summary_large_image' %>
<%= tag.meta name: 'twitter:site', content: "@baka" %>
<%= tag.meta name: 'twitter:title', content: meta_title %>
<%= tag.meta name: 'twitter:description', content: meta_description %>
<%= tag.meta name: 'twitter:image', content: meta_image %>

<meta name="view-transition" content="same-origin">
