<div class="bg-gray-50 dark:bg-gray-900 font-sans">
  <div class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto py-8 sm:py-10">
      <div class="relative overflow-hidden rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800 lg:p-8">
        <%= render 'shared/decorative_ornament' %>

        <header class="relative z-10 mb-6 border-b border-gray-200 pb-6 dark:border-gray-700">
          <h1 class="text-xl font-extrabold leading-tight text-gray-900 drop-shadow dark:text-gray-100 sm:text-2xl lg:text-3xl">
            <%= @bookshelf.title %>
          </h1>

          <dl class="mt-4 space-y-3 text-sm">
            <div>
              <dt class="font-medium text-gray-600 dark:text-gray-400">Автор</dt>
              <dd class="mt-1 text-gray-900 dark:text-gray-200">
                <%= link_to @bookshelf.user_name,
                            profile_path(@bookshelf.user_sqid),
                            class: 'hover:text-cyan-700 dark:hover:text-rose-600 transition-colors duration-200' %>
              </dd>
            </div>
            <% if @bookshelf.description.present? %>
              <div>
                <dt class="font-medium text-gray-600 dark:text-gray-400">Опис</dt>
                <dd class="mt-1 leading-relaxed text-gray-700 dark:text-gray-300">
                  <%= @bookshelf.description %>
                </dd>
              </div>
            <% end %>
          </dl>
        </header>

        <div class="relative z-10">
          <%= render partial: 'fiction_lists/dynamic_content',
                     locals: { fictions: @fictions, pagy: @pagy } %>
        </div>
      </div>
    </div>
  </div>
</div>
