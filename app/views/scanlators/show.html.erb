<div class="bg-stone-100 dark:bg-stone-900">
  <div class="relative w-full">
    <!-- Anime-style Header Section -->
    <div class="bg-stone-800 bg-blend-overlay bg-no-repeat bg-cover bg-center relative overflow-hidden" style="background-image: url('<%= @scanlator.banner.present? ? url_for(@scanlator.banner) : asset_path('scanlator_banner.webp') %>');">
      <div class="absolute inset-0 bg-gradient-to-r from-stone-900 via-transparent to-stone-900 opacity-70"></div>
      <div class="container mx-auto px-4 py-8 relative z-10">
        <div class="flex flex-col lg:flex-row items-center justify-between">
          <div class="flex items-center mb-4 md:mb-0">
            <div class="w-24 h-24 md:w-32 md:h-32 rounded-full bg-no-repeat bg-cover bg-center border-4 border-stone-300 shadow-lg transform hover:scale-110 transition-transform duration-300" style="background-image: url('<%= @scanlator.avatar.present? ? url_for(@scanlator.avatar) : asset_path('scanlator_avatar.webp') %>');"></div>
            <div class="ml-4">
              <%= tag.h1 @scanlator.title, class: "text-3xl md:text-4xl text-stone-100 font-bold mb-2 text-shadow-lg anime-text" %>
              <%= link_to "https://t.me/#{@scanlator.telegram_id}", target: '_blank', rel: 'noopener noreferrer', class: 'text-lg text-stone-300 hover:text-stone-100 transition-colors duration-300 hover:underline anime-text' do %>
                @<%= @scanlator.telegram_id %>
              <% end if @scanlator.telegram_id? %>
            </div>
          </div>

          <!-- Stats and Links Section -->
          <div class="flex flex-col lg:flex-row lg:items-center lg:space-x-4">
            <!-- Stats Row 1 - Always visible -->
            <div class="flex items-center justify-center lg:justify-end space-x-2 sm:space-x-4 mb-4 lg:mb-0">
              <!-- Chapters -->
              <div class="text-center bg-stone-800/50 rounded-lg p-2 sm:p-3 shadow-lg">
                <%= tag.p @scanlator.chapters.size, class: 'text-xl sm:text-2xl md:text-3xl font-bold anime-text text-stone-100' %>
                <p class="text-xs sm:text-sm md:text-base text-stone-300">Розділів</p>
              </div>

              <!-- Readings -->
              <div class="text-center bg-stone-800/50 rounded-lg p-2 sm:p-3 shadow-lg">
                <%= tag.p @scanlator.chapters.sum(:views), class: "text-xl sm:text-2xl md:text-3xl font-bold anime-text text-stone-100" %>
                <p class="text-xs sm:text-sm md:text-base text-stone-300">Прочитань</p>
              </div>

              <!-- Status -->
              <div class="text-center bg-stone-800/50 rounded-lg p-2 sm:p-3 shadow-lg">
                <% if @scanlator.active_this_month? %>
                  <%= tag.p "Актив.", class: "text-base sm:text-lg md:text-xl font-bold anime-text text-green-400" %>
                <% else %>
                  <%= tag.p "Неакт.", class: "text-base sm:text-lg md:text-xl font-bold anime-text text-red-400" %>
                <% end %>
                <p class="text-xs sm:text-sm md:text-base text-stone-300">Статус</p>
              </div>

              <!-- Rating -->
              <div class="text-center bg-stone-800/50 rounded-lg p-2 sm:p-3 shadow-lg">
                <div class="flex items-center justify-center mb-1">
                  <% rating = @scanlator.average_rating %>
                  <% (1..5).each do |star| %>
                    <% if rating >= star %>
                      <svg class="w-3 h-3 sm:w-4 sm:h-4 text-yellow-400 fill-current" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                    <% elsif rating >= star - 0.5 %>
                      <div class="relative">
                        <svg class="w-3 h-3 sm:w-4 sm:h-4 text-stone-400 fill-current" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                        <svg class="w-3 h-3 sm:w-4 sm:h-4 text-yellow-400 fill-current absolute top-0 left-0 overflow-hidden" style="clip-path: inset(0 50% 0 0);" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      </div>
                    <% else %>
                      <svg class="w-3 h-3 sm:w-4 sm:h-4 text-stone-400 fill-current" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                    <% end %>
                  <% end %>
                </div>
                <% if rating > 0 %>
                  <%= tag.p number_with_precision(rating, precision: 1), class: "text-base sm:text-xl md:text-2xl font-bold anime-text text-stone-100" %>
                  <p class="text-xs sm:text-sm md:text-base text-stone-300">Рейтинг (<%= @scanlator.total_rating_count %>)</p>
                <% else %>
                  <%= tag.p "—", class: "text-base sm:text-xl md:text-2xl font-bold anime-text text-stone-400" %>
                  <p class="text-xs sm:text-sm md:text-base text-stone-300">Рейтинг</p>
                <% end %>
              </div>
            </div>

            <!-- Links Row 2 - Only visible on smaller screens, inline on lg+ -->
            <% if @scanlator.bank_url? || @scanlator.extra_url? %>
              <div class="flex justify-center lg:justify-end space-x-3">
                <% if @scanlator.bank_url? %>
                  <%= link_to https_url(@scanlator.bank_url), class: "group relative w-10 h-10 sm:w-12 sm:h-12 bg-gradient-to-br from-stone-700 to-stone-900 rounded-full overflow-hidden shadow-lg transition-all duration-300 hover:scale-110 hover:shadow-2xl", target: "_blank", rel: "noopener noreferrer" do %>
                    <div class="absolute inset-0 bg-stone-300 opacity-0 group-hover:opacity-20 transition-opacity duration-300"></div>
                    <svg class="w-5 h-5 sm:w-6 sm:h-6 absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 text-stone-100" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
                    </svg>
                  <% end %>
                <% end %>

                <% if @scanlator.extra_url? %>
                  <%= link_to https_url(@scanlator.extra_url), class: "group relative w-10 h-10 sm:w-12 sm:h-12 bg-gradient-to-br from-stone-500 to-stone-700 rounded-full overflow-hidden shadow-lg transition-all duration-300 hover:scale-110 hover:shadow-2xl", target: "_blank", rel: "noopener noreferrer" do %>
                    <div class="absolute inset-0 bg-stone-300 opacity-0 group-hover:opacity-20 transition-opacity duration-300"></div>
                    <svg class="w-5 h-5 sm:w-6 sm:h-6 absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 text-stone-100" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
                    </svg>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <% scanlator_sidebar = @scanlator.description? || @scanlator.notice? %>
    <div class="container mx-auto px-4 py-16 <%= scanlator_sidebar ? 'max-w-5xl' : 'max-w-3xl' %>">
      <div class="grid grid-cols-1 <%= scanlator_sidebar ? 'lg:grid-cols-3 ' : 'lg:grid-cols-2' %> gap-8">
        <!-- Sidebar: опис та оголошення -->
        <% if scanlator_sidebar %>
          <% scanlator_sidebar_link_class = 'underline font-medium text-cyan-700 dark:text-rose-400 hover:text-cyan-900 dark:hover:text-rose-300 break-words' %>
          <% scanlator_sidebar_card = 'relative overflow-hidden rounded-xl border border-stone-200 bg-stone-50 shadow-md dark:border-stone-700 dark:bg-stone-800/95' %>
          <% scanlator_sidebar_mascot = 'pointer-events-none absolute bottom-4 right-4 select-none text-4xl text-stone-300 opacity-[0.15] transform -rotate-12 dark:text-stone-600 dark:opacity-20 sm:text-5xl sm:bottom-5 sm:right-5' %>
          <div class="lg:col-span-1 flex flex-col gap-5">
            <% if @scanlator.description? %>
              <section class="<%= scanlator_sidebar_card %>">
                <div class="h-px w-full bg-gradient-to-r from-transparent via-cyan-600/50 to-transparent dark:via-rose-500/40"></div>
                <div class="relative px-5 py-6 sm:px-6 sm:py-7">
                  <article>
                    <header class="mb-3 flex items-center gap-2.5">
                      <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-cyan-100 text-cyan-700 dark:bg-rose-900/25 dark:text-rose-400">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                        </svg>
                      </span>
                      <h2 class="text-xs font-semibold uppercase tracking-wider text-stone-500 dark:text-stone-400">Про команду</h2>
                    </header>
                    <div class="border-l-2 border-cyan-700/30 pl-4 text-sm leading-relaxed text-stone-700 dark:border-rose-500/35 dark:text-stone-300 md:text-[15px]">
                      <%= linkify_urls(@scanlator.description, link_class: scanlator_sidebar_link_class) %>
                    </div>
                  </article>
                  <div class="<%= scanlator_sidebar_mascot %>" aria-hidden="true">(^o^)</div>
                </div>
              </section>
            <% end %>

            <% if @scanlator.notice? %>
              <section class="<%= scanlator_sidebar_card %>">
                <div class="h-px w-full bg-gradient-to-r from-transparent via-cyan-600/50 to-transparent dark:via-rose-500/40"></div>
                <div class="relative px-5 py-6 sm:px-6 sm:py-7">
                  <article>
                    <header class="mb-3 flex items-center gap-2.5">
                      <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-cyan-100 text-cyan-700 dark:bg-rose-900/25 dark:text-rose-400">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M7.556 8.5h8m-8 3.5H12m7.111-7H4.89a.896.896 0 0 0-.629.256.868.868 0 0 0-.26.619v9.25c0 .232.094.455.26.619A.896.896 0 0 0 4.89 16H9l3 4 3-4h4.111a.896.896 0 0 0 .629-.256.868.868 0 0 0 .26-.619v-9.25a.868.868 0 0 0-.26-.619.896.896 0 0 0-.63-.256Z" />
                        </svg>
                      </span>
                      <h2 class="text-xs font-semibold uppercase tracking-wider text-stone-500 dark:text-stone-400">Оголошення</h2>
                    </header>
                    <div class="border-l-2 border-cyan-700/40 pl-4 text-sm leading-relaxed text-stone-700 dark:border-rose-500/45 dark:text-stone-300 md:text-[15px]">
                      <%= linkify_urls(@scanlator.notice, link_class: scanlator_sidebar_link_class) %>
                    </div>
                  </article>
                  <% unless @scanlator.description? %>
                    <div class="<%= scanlator_sidebar_mascot %>" aria-hidden="true">(^o^)</div>
                  <% end %>
                </div>
              </section>
            <% end %>
          </div>
        <% end %>
        <!-- Fictions Grid -->
        <% if @fictions.ids.size > 0 %>
          <div data-controller="fiction-picker" class="lg:col-span-2">
            <div class="p-4 bg-stone-100 dark:bg-gray-800 rounded-lg shadow-md overflow-hidden mb-8 lg:mb-0">
              <% if @fictions.ids.size > 1 %>
                <div class="flex md:justify-center lg:justify-start space-x-2 overflow-x-auto pt-4 pb-4 mb-4 -mx-2 px-2">
                  <% @fictions.each_with_index do |fiction, index| %>
                    <div class="relative transition duration-300 transform hover:scale-105 cursor-pointer flex-shrink-0 w-14 h-20 sm:w-16 sm:h-24">
                      <%= image_tag cover_card_url(fiction.cover),
                          alt: fiction.cover.blob.filename.to_s,
                          class: "w-full h-full object-cover rounded-md shadow-sm #{index == 0 ? 'ring-2 ring-stone-500' : ''}",
                          data: {
                            action: "click->fiction-picker#selectFiction",
                            fiction_picker_target: "image",
                            fiction_picker_id_param: fiction.id
                          } %>
                    </div>
                  <% end %>
                </div>
              <% end %>
              <%= turbo_frame_tag "fiction_details" do %>
                <%= render partial: 'fictions/fiction_details', locals: { fiction: @fictions.first } %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<style>
  .anime-text {
    text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
    letter-spacing: 1px;
  }
</style>
