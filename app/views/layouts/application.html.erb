<!DOCTYPE html>
<html lang="uk">
  <head>
    <script nonce="<%= content_security_policy_nonce %>">
      (function() {
        var isDark =
          localStorage.getItem('color-theme') === 'dark' ||
          (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches);
        document.documentElement.classList.toggle('dark', isDark);
      })();
    </script>

    <%= render 'shared/meta', publication: @publication, chapter: @chapter, fiction: @fiction %>

    <%= yield :head %>

    <%= json_ld_script(site_identity_meta) %>

    <%= json_ld_script(article_meta(@publication)) if article_meta? %>

    <%= json_ld_script(chapter_article_meta(@chapter)) if chapter_reader_meta? && @chapter %>

    <%= json_ld_script(fiction_book_meta(@fiction)) if fiction_reader_meta? && @fiction %>

    <%= json_ld_script(about_page_meta) if about_page_meta? %>

    <%= json_ld_script(profile_page_meta(@scanlator)) if profile_page_meta? %>

    <%= json_ld_script(user_profile_meta(@user)) if user_profile_meta? %>

    <%= json_ld_script(video_meta(@youtube_video)) if video_meta?(@youtube_video) %>

    <%= csrf_meta_tags %>
    <%= action_cable_meta_tag %>
    <%= csp_meta_tag %>
    <%= tag.link rel: 'manifest', href: pwa_manifest_path(format: :json) %>
    <%= tag.meta name: 'theme-color', content: '#78716c' %>
    <%= tag.link rel: 'apple-touch-icon', href: '/icon-192.png' %>
    <meta name="turbo-cache-control" content="no-preview">
    <meta name="view-transition" content="same-origin">
    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">
    <%# data-turbo-track="reload" — digested Propshaft assets only; CDN URLs (flatpickr, Google Fonts) omit track %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <% global_stylesheets.each do |stylesheet| %>
      <%= stylesheet_link_tag stylesheet, "data-turbo-track": "reload" %>
    <% end %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <% if requires_flatpickr_styles? %>
      <%= stylesheet_link_tag flatpickr_stylesheet_url, media: 'all' %>
    <% end %>
    <% page_stylesheets.each do |stylesheet| %>
      <%= stylesheet_link_tag stylesheet, "data-turbo-track": "reload" %>
    <% end %>
    <%= stylesheet_link_tag reader_google_fonts_stylesheet_url, media: 'all' if requires_reader_google_fonts? %>
    <%= javascript_importmap_tags %>
    <%= favicon_link_tag asset_path('favicon.ico') %>
    <%= tag.link rel: 'icon', type: 'image/png', sizes: '192x192', href: '/icon-192.png' %>
    <%= tag.link rel: 'icon', type: 'image/png', sizes: '512x512', href: '/icon-512.png' %>

    <% if requires_tinymce? %>
      <%= tinymce_script_tags %>
      <%= javascript_include_tag 'tinymce_initializer' %>
    <% end %>

    <% if requires_legacy_font_toggler? %>
      <%= javascript_import_module_tag 'font_toggler' %>
    <% end %>
  </head>

  <body class="min-w-[375px] lg:min-w-[1250px] relative flex flex-col min-h-screen" data-load-google-scripts="<%= Rails.env.production? %>" data-load-adsense="<%= adsense_allowed? %>">
    <% if user_signed_in? %>
      <div class="hidden" aria-hidden="true" <%= tag.attributes(data: session_watchdog_stimulus_data) %>></div>
    <% end %>
    <div id="page-background" class="fixed inset-0 -z-10 bg-no-repeat bg-cover bg-center" style="background-image: url(<%= asset_path('bg.webp') %>);">
      <div class="absolute inset-0 bg-gradient-to-br from-stone-100 to-stone-200 dark:from-gray-800 dark:to-gray-900 opacity-95"></div>
      <%= image_tag 'bg.webp', alt: 'bg image', class: 'hidden' %>
    </div>
    <% unless immersive_reader_layout? %>
      <div id="site-navbar" class="relative z-50">
        <%= render "shared/navbar" %>
      </div>
    <% end %>
    <%= turbo_frame_tag 'application-notice' do %>
      <%= render "shared/notice" if notice %>
    <% end %>
    <%= turbo_frame_tag "application-alert" do %>
      <%= render "shared/alert" if alert %>
    <% end %>
    <main>
      <%= yield %>
      <%= turbo_frame_tag 'catch-pokemon' do %>
        <%= render 'shared/pokemon', pokemon: @wild_pokemon %>
      <% end if @wild_pokemon %>
    </main>
    <% unless immersive_reader_layout? %>
      <div id="site-footer">
        <%= render "shared/footer" %>
      </div>
    <% end %>
    <%= render "shared/cookie_consent_banner" %>
    <% if requires_mode_toggler? %>
      <%= javascript_import_module_tag 'mode_toggler' %>
    <% end %>
    <%= render "shared/chat_widget" unless chapters_show_page? %>
  </body>
</html>
