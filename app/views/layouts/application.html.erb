<!DOCTYPE html>
<html lang="uk">
  <head>
    <script>
      (function() {
        var isDark =
          localStorage.getItem('color-theme') === 'dark' ||
          (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches);
        if (isDark) {
          document.documentElement.classList.add('dark');
          document.write('<style>#theme-toggle-dark-icon{display:none;}#theme-toggle-light-icon{display:inline;}</style>');
        } else {
          document.documentElement.classList.remove('dark');
          document.write('<style>#theme-toggle-dark-icon{display:inline;}#theme-toggle-light-icon{display:none;}</style>');
        }
      })();
    </script>

    <%= render 'shared/meta', publication: @publication, chapter: @chapter, fiction: @fiction %>

    <%= json_ld_script(site_identity_meta) %>

    <%= json_ld_script(article_meta(@publication)) if article_meta? %>

    <%= json_ld_script(chapter_article_meta(@chapter)) if chapter_reader_meta? && @chapter %>

    <%= json_ld_script(fiction_book_meta(@fiction)) if fiction_reader_meta? && @fiction %>

    <%= json_ld_script(about_page_meta) if about_page_meta? %>

    <%= json_ld_script(profile_page_meta(@scanlator)) if profile_page_meta? %>

    <%= json_ld_script(user_profile_meta(@user)) if user_profile_meta? %>

    <%= json_ld_script(video_meta(@youtube_video)) if video_meta?(@youtube_video) %>

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <% if controller_name == 'chapters' && %w[new create edit update].include?(action_name) %>
      <%= stylesheet_link_tag 'https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.css', media: 'all', 'data-turbo-track': 'reload' %>
    <% end %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "https://fonts.googleapis.com/css2?family=Oswald:wght@200;300;400&display=swap", "data-turbolinks-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= favicon_link_tag asset_path('favicon.ico') %>

    <% if %i[fictions chapters].include?(controller_name.to_sym) && action_name.to_sym == :show %>
      <%= javascript_include_tag 'accordion' %>
    <% end %>

    <% if requires_tinymce? %>
      <%= tinymce_assets %>
      <%= javascript_include_tag 'tinymce_initializer' %>
    <% end %>

    <% if requires_sweetalert? %>
      <%= turbo_frame_tag 'sweet-alert' do %>
        <%= render 'shared/sweet_alert' %>
      <% end %>
    <% end %>

    <%= javascript_include_tag 'font_toggler' if requires_font? %>
    <%= javascript_include_tag 'mode_toggler' %>
    <%= javascript_include_tag 'note_handler' %>

    <% if controller_name.to_sym == :translation_requests %>
      <%= javascript_import_module_tag 'translation_requests' %>
    <% end %>
  </head>

  <body class="min-w-[375px] lg:min-w-[1250px] relative flex flex-col min-h-screen" data-load-google-scripts="<%= Rails.env.production? %>" data-load-adsense="<%= adsense_allowed? %>">
    <div class="fixed inset-0 -z-10 bg-no-repeat bg-cover bg-center" style="background-image: url(<%= controller_name.to_sym == :scanlators && action_name.to_sym == :show ? asset_path('modal-bg.webp') : asset_path('bg.webp') %>);">
      <div class="absolute inset-0 bg-gradient-to-br from-stone-100 to-stone-200 dark:from-gray-800 dark:to-gray-900 opacity-95"></div>
      <%= image_tag 'bg.webp', alt: 'bg image', class: 'hidden' %>
    </div>
    <%= render "shared/navbar" unless immersive_reader_layout? %>
    <%= turbo_frame_tag 'application-notice' do %>
      <%= render "shared/notice" if notice %>
    <% end %>
    <%= turbo_frame_tag "application-alert" do %>
      <%= render "shared/alert" if alert %>
    <% end %>
    <main>
      <%= yield %>
      <%= turbo_frame_tag 'catch-pokemon' do %>
        <%= render 'shared/pokemon', pokemon: @wild_pokemon %>
      <% end if @wild_pokemon %>
    </main>
    <%= render "shared/footer" unless immersive_reader_layout? %>
    <%= render "shared/cookie_consent_banner" %>
    <%= javascript_include_tag 'cookie_consent' %>
    <%= render "shared/chat_widget" unless chapters_show_page? %>
  </body>
</html>
