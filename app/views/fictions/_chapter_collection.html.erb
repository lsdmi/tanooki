<%# locals: fiction:, chapters:, order: :asc, compact: false (optional), drawer_toc: false (optional), current_chapter: nil (optional) %>
<% list_order = local_assigns.fetch(:order, :asc) %>
<% compact = local_assigns.fetch(:compact, false) %>
<% drawer_toc = local_assigns.fetch(:drawer_toc, false) %>
<% sheet = compact && drawer_toc %>
<% current_chapter_id = local_assigns[:current_chapter]&.id %>
<% drawer_accordion_opened = false %>
<% accordion_shell = sheet ? 'border-b border-stone-200/45 bg-white/10 backdrop-blur-md last:border-b-0 dark:border-zinc-100/10 dark:bg-black/15' : (compact ? 'border-b border-zinc-800 bg-zinc-950 last:border-b-0' : 'bg-white dark:bg-gray-800 rounded-lg shadow-md transition-shadow duration-300 hover:shadow-md dark:hover:shadow-lg') %>
<% accordion_head = sheet ? 'border-b border-stone-200/40 bg-white/10 px-4 py-4 backdrop-blur-sm hover:bg-white/20 dark:border-zinc-100/10 dark:bg-black/15 dark:hover:bg-black/25' : (compact ? 'border-b border-zinc-800/90 bg-zinc-950 px-4 py-4 hover:bg-zinc-900' : 'bg-gradient-to-r from-stone-100 to-stone-200 dark:from-gray-700 dark:to-gray-600 p-4') %>
<% accordion_body = sheet ? 'border-0 bg-white/5 dark:bg-black/10' : (compact ? 'border-0 bg-zinc-900/40' : 'rounded-b border border-stone-200 bg-white dark:border-gray-700 dark:bg-gray-900') %>
<div class="<%= compact ? 'my-0' : 'my-6 space-y-4' %>" data-chapters-accordion-root<%= ' data-chapters-accordion-default-open' if sheet %>>
  <% chapter_list_sections(chapters, order: list_order).each_with_index do |section, section_index| %>
    <% section_chapters = section[:chapters] %>
    <% accordion_open = sheet && !drawer_accordion_opened && (chapter_list_section_current?(section, current_chapter_id) || (current_chapter_id.nil? && section_index.zero?)) %>
    <% drawer_accordion_opened = true if accordion_open %>
    <% preload_section = accordion_open %>
    <% section_path = fiction_chapter_section_path(fiction, section[:section_key], order: list_order) %>
    <div class="accordion overflow-hidden <%= accordion_shell %>">
      <div class="accordion-header flex cursor-pointer items-center justify-between gap-2 <%= accordion_head %>">
        <h3 class="min-w-0 flex-1 truncate text-left <%= sheet ? 'text-sm font-normal text-stone-800 dark:text-white' : (compact ? 'text-sm font-normal text-white' : 'text-lg font-semibold text-stone-800 dark:text-gray-200') %>">
          <%= section[:title] %>
        </h3>
        <div class="flex shrink-0 items-center gap-1">
          <% if !compact && chapters_allow_epub_download?(section_chapters) %>
            <div data-controller="epub-download"
                 data-epub-download-url-value="<%= epub_multiple_downloads_path %>"
                 data-epub-download-params-value="<%= { chapter_ids: chapter_list_section_ids(section_chapters), volume_title: section[:epub_title] }.to_json %>">
              <button data-epub-download-target="button"
                      data-action="click->epub-download#download"
                      class="text-sm bg-stone-200 dark:bg-gray-700 hover:bg-stone-300 dark:hover:bg-gray-600 text-stone-700 dark:text-gray-300 py-1 px-2 rounded">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
              </button>
            </div>
          <% end %>
          <button type="button" class="accordion-icon transition-transform duration-200 <%= accordion_open ? 'rotate-180 ' : '' %><%= compact ? (sheet ? 'text-stone-500 dark:text-zinc-400' : 'text-zinc-400') : 'transform text-stone-600 hover:text-stone-800 dark:text-gray-400 dark:hover:text-gray-200' %>" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" class="<%= compact ? 'h-5 w-5' : 'h-6 w-6' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
        </div>
      </div>
      <div class="accordion-content <%= accordion_open ? '' : 'hidden' %> max-h-96 overflow-y-auto <%= accordion_body %>">
        <% if preload_section %>
          <%= render 'fictions/chapter_section_items',
                     chapters: section_chapters.includes(:scanlators),
                     compact: compact,
                     current_chapter: local_assigns[:current_chapter] %>
        <% else %>
          <% lazy_params = { chapter_ids: chapter_list_section_ids(section_chapters).join(',') } %>
          <% lazy_params[:compact] = true if compact %>
          <% lazy_params[:current_chapter_id] = current_chapter_id if current_chapter_id.present? %>
          <div data-chapter-section-url="<%= section_path %>"
               data-chapter-section-params="<%= lazy_params.to_json %>">
            <p class="px-4 py-3 text-sm text-stone-500 dark:text-gray-400 chapter-section-placeholder">Натисніть, щоб завантажити розділи…</p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<script>initializeAccordion()</script>
