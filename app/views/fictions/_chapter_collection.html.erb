<%# locals: fiction:, chapters:, order: :asc, reader_drawer: false (optional), current_chapter: nil (optional) %>
<% list_order = local_assigns.fetch(:order, :asc) %>
<% reader_drawer = local_assigns.fetch(:reader_drawer, false) %>
<% current_chapter_id = local_assigns[:current_chapter]&.id %>
<% drawer_accordion_opened = false %>
<% accordion_shell = if reader_drawer
  'border-b border-stone-200 last:border-b-0 dark:border-zinc-700'
else
  'bg-white dark:bg-gray-800 rounded-lg shadow-md transition-shadow duration-300 hover:shadow-md dark:hover:shadow-lg'
end %>
<% accordion_head = if reader_drawer
  'flex cursor-pointer items-center justify-between gap-2 px-4 py-3.5 hover:bg-stone-50 dark:hover:bg-zinc-800/60'
else
  'bg-gradient-to-r from-stone-100 to-stone-200 dark:from-gray-700 dark:to-gray-600 p-4'
end %>
<% accordion_body = if reader_drawer
  'border-0 bg-transparent'
else
  'rounded-b border border-stone-200 bg-white dark:border-gray-700 dark:bg-gray-900'
end %>
<div class="<%= reader_drawer ? 'my-0' : 'my-6 space-y-4' %>" data-controller="chapters-accordion" data-chapters-accordion-root<%= ' data-chapters-accordion-default-open' if reader_drawer %>>
  <% chapter_list_sections(chapters, order: list_order).each_with_index do |section, section_index| %>
    <% section_chapters = section[:chapters] %>
    <% accordion_open = reader_drawer && !drawer_accordion_opened && (chapter_list_section_current?(section, current_chapter_id) || (current_chapter_id.nil? && section_index.zero?)) %>
    <% drawer_accordion_opened = true if accordion_open %>
    <% preload_section = accordion_open %>
    <% section_path = fiction_chapter_section_path(fiction, section[:section_key], order: list_order) %>
    <div class="accordion overflow-hidden <%= accordion_shell %>">
      <div class="accordion-header flex cursor-pointer items-center justify-between gap-2 <%= accordion_head %>"
           role="button"
           tabindex="0"
           aria-expanded="<%= accordion_open ? 'true' : 'false' %>"
           data-action="click->chapters-accordion#toggle keydown.enter->chapters-accordion#toggle keydown.space->chapters-accordion#toggle">
        <h3 class="min-w-0 flex-1 truncate text-left text-sm font-medium text-stone-800 dark:text-zinc-100">
          <%= reader_drawer ? reader_drawer_section_title(section) : section[:title] %>
        </h3>
        <div class="flex shrink-0 items-center gap-1">
          <% if !reader_drawer && epub_download_available?(section_chapters) %>
            <div data-controller="epub-download"
                 data-epub-download-url-value="<%= epub_multiple_downloads_path %>"
                 data-epub-download-params-value="<%= { chapter_ids: chapter_list_section_ids(section_chapters), volume_title: section[:epub_title] }.to_json %>">
              <button data-epub-download-target="button"
                      data-action="click->epub-download#download"
                      class="text-sm bg-stone-200 dark:bg-gray-700 hover:bg-stone-300 dark:hover:bg-gray-600 text-stone-700 dark:text-gray-300 py-1 px-2 rounded"
                      title="Завантажити EPUB">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
              </button>
            </div>
          <% end %>
          <span class="accordion-icon transition-transform duration-200 <%= accordion_open ? 'rotate-180 ' : '' %><%= reader_drawer ? 'text-stone-500 dark:text-zinc-400' : 'transform text-stone-600 hover:text-stone-800 dark:text-gray-400 dark:hover:text-gray-200' %>" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" class="<%= reader_drawer ? 'h-5 w-5' : 'h-6 w-6' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </span>
        </div>
      </div>
      <div class="accordion-content <%= accordion_open ? '' : 'hidden' %> <%= reader_drawer ? '' : 'max-h-96 overflow-y-auto' %> <%= accordion_body %>">
        <% if preload_section %>
          <%= render 'fictions/chapter_section_items',
                     chapters: section_chapters.includes(:scanlators),
                     reader_drawer: reader_drawer,
                     current_chapter: local_assigns[:current_chapter],
                     drawer_progress: local_assigns[:drawer_progress] %>
        <% else %>
          <% lazy_params = {} %>
          <% lazy_params[:reader_drawer] = true if reader_drawer %>
          <% lazy_params[:current_chapter_id] = current_chapter_id if current_chapter_id.present? %>
          <div data-chapter-section-url="<%= section_path %>"
               data-chapter-section-params="<%= lazy_params.to_json %>">
            <p class="px-4 py-3 text-sm text-stone-500 dark:text-zinc-400 chapter-section-placeholder">Натисніть, щоб завантажити розділи…</p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
