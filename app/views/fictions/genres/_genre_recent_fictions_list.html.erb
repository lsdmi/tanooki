<%# locals: skeleton:, pagy:, fictions:, released_by_fiction: %>
<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-3">
  <% fictions.each_with_index do |fiction, i| %>
    <% card = skeleton.genre_thumb_card_locals(fiction, released_n: released_by_fiction[fiction.id].to_i, accent_index: pagy.offset + i) %>
    <article class="group rounded-xl overflow-hidden transition-shadow duration-300 hover:shadow-lg dark:hover:shadow-black/50">
      <%= link_to fiction_path(fiction), class: "relative block aspect-[3/4] bg-gradient-to-br #{card[:accent]} overflow-hidden rounded-t-xl transition-[filter,transform] duration-300 ease-out focus:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-violet-500 group-hover:brightness-105 dark:focus-visible:ring-violet-400" do %>
        <%= image_tag url_for(fiction.cover), alt: fiction.title, class: "absolute inset-0 h-full w-full object-cover transition-transform duration-300 ease-out group-hover:scale-[1.04]", loading: "lazy" %>
        <div class="pointer-events-none absolute inset-x-0 bottom-0 z-10 flex items-end justify-between gap-1.5 bg-gradient-to-t from-black/80 via-black/40 to-transparent px-2 pb-2 pt-10">
          <span class="inline-flex min-w-0 max-w-[58%] items-center gap-1 rounded-md bg-black/40 px-2 py-0.5 text-[10px] font-medium leading-none text-white backdrop-blur-[2px] ring-1 ring-white/15 transition-opacity duration-300 group-hover:opacity-95">
            <svg class="h-3 w-3 shrink-0 text-white/90" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            <span class="truncate tabular-nums"><%= card[:views] %></span>
          </span>
          <span class="inline-flex shrink-0 items-center gap-0.5 rounded-md bg-black/40 px-2 py-0.5 text-[10px] font-semibold text-amber-300 backdrop-blur-[2px] ring-1 ring-white/15 transition-opacity duration-300 group-hover:opacity-95">
            <svg class="h-3 w-3 text-amber-300" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <%= card[:rating] %>
          </span>
        </div>
      <% end %>
      <div class="px-2.5 pb-2.5 pt-2">
        <p class="min-h-[1.25rem] text-sm font-bold leading-tight text-slate-900 dark:text-slate-100">
          <%= link_to card[:title], fiction_path(fiction), class: "block truncate rounded-sm transition-colors hover:text-cyan-600 hover:underline underline-offset-2 dark:hover:text-rose-400 group-hover:text-cyan-700 dark:group-hover:text-rose-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-violet-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-gray-800" %>
        </p>
        <div class="mt-1.5 flex min-w-0 items-center gap-2">
          <span class="shrink-0 rounded-md border border-slate-400/90 bg-slate-100 px-2 py-0.5 text-[10px] font-medium tabular-nums text-slate-600 dark:border-slate-500 dark:bg-slate-700/80 dark:text-slate-200"><%= card[:chapters] %> Розділи</span>
          <span class="min-w-0 truncate text-[10px] font-medium text-slate-700 dark:text-slate-400"><%= card[:status] %></span>
        </div>
      </div>
    </article>
  <% end %>
</div>
<% if pagy.pages > 1 %>
  <div class="pagy-nav pt-4 sm:pt-6">
    <div class="flex justify-center">
      <%== pagy_nav_buttons(pagy,
                            frame_id: 'genre-recent-fictions-page',
                            aria_label: 'Сторінки нових релізів') %>
    </div>
  </div>
<% end %>
