<%# locals: skeleton: FictionGenrePageSkeleton %>
<section class="my-10 lg:my-14" aria-labelledby="genre-new-releases">
  <header class="flex gap-3 sm:gap-4 mb-8 lg:mb-10">
    <div class="w-1.5 shrink-0 self-stretch min-h-[2.75rem] rounded-lg bg-cyan-600 dark:bg-rose-500" aria-hidden="true"></div>
    <div class="min-w-0 pt-0.5">
      <h2 id="genre-new-releases" class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-slate-100 tracking-tight leading-snug">
        <%= skeleton.new_releases_title %>
      </h2>
      <p class="mt-1.5 text-sm sm:text-[15px] text-slate-600 dark:text-slate-300 leading-relaxed max-w-3xl">
        <%= skeleton.new_releases_subtitle %>
      </p>
    </div>
  </header>

  <% new_releases_compact_strip = skeleton.new_releases_featured + skeleton.new_releases_thumbs %>
  <% if new_releases_compact_strip.any? %>
    <%# Below lg: one horizontal row — all ranked cards (top 8) as compact thumb cards %>
    <div
      class="mb-6 flex snap-x snap-mandatory gap-3 overflow-x-auto overscroll-x-contain px-4 pb-3 [-webkit-overflow-scrolling:touch] lg:hidden"
      role="region"
      aria-label="<%= skeleton.new_releases_title %> — горизонтальна стрічка">
      <% new_releases_compact_strip.each do |card| %>
        <%= render 'fictions/genres/new_release_thumb_card', card: card %>
      <% end %>
    </div>
  <% end %>

  <% if skeleton.new_releases_featured.any? %>
    <%# lg+: large featured pair %>
    <div class="mb-6 hidden lg:mb-4 lg:grid lg:grid-cols-2 lg:items-stretch lg:gap-x-4">
      <% skeleton.new_releases_featured.each do |card| %>
        <% fiction = card[:fiction] %>
        <article class="group flex h-full min-h-[240px] w-full flex-col overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-lg ring-1 ring-stone-200/80 transition-shadow duration-300 hover:shadow-xl dark:border-slate-800/75 dark:bg-[#0a181d] dark:shadow-xl dark:shadow-black/30 dark:ring-white/[0.06] dark:hover:shadow-2xl dark:hover:ring-white/[0.1] sm:flex-row sm:items-stretch">
          <%= link_to fiction_path(fiction), class: "relative aspect-[3/4] w-full shrink-0 bg-gradient-to-br #{card[:accent]} sm:aspect-auto sm:w-[34%] sm:self-stretch sm:min-h-0 overflow-hidden rounded-t-2xl sm:rounded-l-2xl sm:rounded-tr-none block transition-[filter,transform] duration-300 ease-out focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500 focus-visible:ring-inset group-hover:brightness-110 dark:focus-visible:ring-rose-500" do %>
            <% if card[:rank].present? %>
              <%= render Ui::GenrePageTagComponent.new(variant: :rank, label: card[:rank], rank_size: :featured) %>
            <% end %>
            <%= image_tag cover_card_url(fiction.cover), alt: fiction.title, class: "absolute inset-0 h-full w-full object-cover transition-transform duration-300 ease-out group-hover:scale-[1.04]", loading: "lazy" %>
          <% end %>
          <div class="relative isolate flex min-h-0 flex-1 flex-col overflow-hidden border-stone-200 bg-gradient-to-br from-stone-50 via-white to-stone-100 p-5 sm:border-l sm:p-6 sm:pl-7 dark:border-white/[0.05] dark:from-[#142a32]/38 dark:via-[#0f252c] dark:to-[#0a171c]">
            <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
              <svg class="absolute -right-4 -top-4 h-40 w-40 text-cyan-600/12 sm:h-48 sm:w-48 dark:text-cyan-300/18" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="0.55">
                <path d="M102 2c-18 10-32 26-40 46a52 52 0 00-4 22M78 2a62 62 0 00-28 36 62 62 0 00-2 18M102 22a48 48 0 00-34 28" stroke-linecap="round" />
                <circle cx="88" cy="14" r="3" fill="rgba(165,243,252,0.22)" stroke="none" />
                <path d="M92 34c8 4 14 12 16 22M68 8c6 8 10 18 10 28" stroke-linecap="round" />
              </svg>
              <svg class="absolute -bottom-6 -left-6 h-36 w-36 text-amber-500/10 sm:h-44 sm:w-44 dark:text-amber-100/10" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="0.5">
                <path d="M-2 98c20-12 36-30 46-52a55 55 0 004-24M22 98a60 60 0 0028-38 60 60 0 002-20M-2 78a50 50 0 0034-30" stroke-linecap="round" />
                <path d="M8 72c10-6 18-16 22-28M28 92c-6-10-8-20-6-32" stroke-linecap="round" />
              </svg>
              <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_70%_20%,rgba(34,211,238,0.06),transparent_55%)] dark:bg-[radial-gradient(ellipse_80%_60%_at_70%_20%,rgba(34,211,238,0.045),transparent_55%)]"></div>
            </div>
            <div class="relative z-[1] flex min-h-0 flex-1 flex-col">
              <h3 class="line-clamp-2 text-lg font-bold leading-snug text-slate-900 sm:text-xl dark:text-white">
                <%= link_to card[:title], fiction_path(fiction), class: "line-clamp-2 rounded-lg text-inherit transition-colors hover:text-cyan-700 hover:underline underline-offset-2 group-hover:text-cyan-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:hover:text-rose-200 dark:group-hover:text-rose-100 dark:focus-visible:ring-rose-500 dark:focus-visible:ring-offset-[#0f252c]" %>
              </h3>
              <p class="mt-1.5 text-sm text-slate-600 dark:text-slate-300">
                <%= card[:author] %> · <%= card[:chapters] %> розділів
              </p>
              <ul class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-1.5 text-xs text-slate-600 dark:text-slate-300">
                <li class="inline-flex items-center gap-1.5">
                  <svg class="h-3.5 w-3.5 shrink-0 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                  <%= card[:rating] %>
                </li>
                <li class="inline-flex items-center gap-1.5">
                  <svg class="h-3.5 w-3.5 shrink-0 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                  <%= card[:views] %>
                </li>
                <li class="inline-flex items-center gap-1.5">
                  <svg class="h-3.5 w-3.5 shrink-0 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" /></svg>
                  <%= card[:status] %>
                </li>
              </ul>
              <div class="mt-3 flex min-h-0 flex-1 flex-col">
                <p class="line-clamp-4 text-sm leading-relaxed text-slate-700 dark:text-slate-200">
                  <%= card[:excerpt] %>
                </p>
                <% if card[:genres].present? %>
                  <%= render Ui::GenrePageTagListComponent.new(genres: card[:genres]) %>
                <% end %>
              </div>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% end %>

  <% if skeleton.new_releases_thumbs.any? %>
    <%# lg+ only: ranks 3–8 as grid (mobile uses single strip above) %>
    <div
      class="hidden lg:grid lg:grid-cols-6 lg:gap-4 lg:mx-0 lg:overflow-visible lg:px-0 lg:pb-0"
      role="region"
      aria-label="<%= skeleton.new_releases_title %> — решта топу">
      <% skeleton.new_releases_thumbs.each do |card| %>
        <%= render 'fictions/genres/new_release_thumb_card', card: card %>
      <% end %>
    </div>
  <% end %>
</section>
