<%# locals: fiction:, order:, compact: false (optional), drawer_toc: false (optional), current_chapter: nil (optional) %>
<% compact = local_assigns.fetch(:compact, false) %>
<% drawer_toc = local_assigns.fetch(:drawer_toc, false) %>
<div class="<%= compact ? '' : 'rounded-lg' %>">
  <div id="chapters-list" class="<%= compact ? '' : 'space-y-6' %>">
    <% chapters = order.to_sym == :desc ? ordered_chapters_desc(fiction, viewer: current_user).includes(:scanlators) : ordered_chapters(fiction, viewer: current_user).includes(:scanlators) %>
    <%= render 'fictions/chapter_collection', chapters: chapters, compact: compact, drawer_toc: drawer_toc, current_chapter: local_assigns[:current_chapter] %>
  </div>
</div>
