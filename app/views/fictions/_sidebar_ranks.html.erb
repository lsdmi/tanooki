<%# locals: show_presenter: %>
<div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-4 border border-stone-200 dark:border-gray-700 relative overflow-hidden">
  <%= render 'shared/jellyfish_ornament' %>
  <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Відзнаки та нагороди</h3>
  <div class="relative">
    <% main_rank = show_presenter.ranks.first %>
    <% main_badge_slug = main_rank && genre_badge_slug(main_rank[0]) %>
    <% if main_badge_slug.present? && badge_asset_available?(main_badge_slug) %>
      <%= link_to fiction_genre_fictions_path(main_badge_slug),
                  turbo_drive_visit_data.merge(
                    class: 'text-center mb-4 block text-inherit no-underline rounded-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-yellow-400 dark:focus-visible:ring-yellow-500 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-50 dark:focus-visible:ring-offset-gray-800'
                  ) do %>
        <div class="relative inline-block">
          <%= image_tag asset_path("badges/#{main_badge_slug}.webp"),
                        alt: "badge-#{main_badge_slug}",
                        class: "h-24 w-24 rounded-full object-cover shadow-lg ring-4 ring-yellow-400 dark:ring-yellow-500 transition duration-300 ease-in-out transform hover:-translate-y-1 hover:scale-105" %>
          <div class="absolute -top-2 -right-2 bg-red-500 text-white text-lg font-bold w-8 h-8 rounded-full flex items-center justify-center shadow-lg">
            #<%= main_rank[1] %>
          </div>
        </div>
        <div class="mt-3 text-sm font-bold text-gray-900 dark:text-white">
          <%= main_rank[0].to_s.titleize %>
        </div>
      <% end %>
    <% end %>

    <% if show_presenter.ranks.to_a[1..3].any? %>
      <div class="flex justify-center space-x-3">
        <% show_presenter.ranks.to_a[1..3].each do |rank_data| %>
          <% rank, value = rank_data %>
          <% rank_badge_slug = genre_badge_slug(rank) %>
          <% if rank_badge_slug.present? && badge_asset_available?(rank_badge_slug) %>
            <%= link_to fiction_genre_fictions_path(rank_badge_slug),
                        turbo_drive_visit_data.merge(
                          class: 'text-center text-inherit no-underline inline-block rounded-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 dark:focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-50 dark:focus-visible:ring-offset-gray-800'
                        ) do %>
              <div class="relative">
                <%= image_tag asset_path("badges/#{rank_badge_slug}.webp"),
                              alt: "badge-#{rank_badge_slug}",
                              class: "h-12 w-12 rounded-full object-cover shadow-md transition duration-300 ease-in-out transform hover:-translate-y-1 hover:scale-105" %>
                <div class="absolute -top-1 -right-1 bg-blue-500 text-white text-xs font-bold w-5 h-5 rounded-full flex items-center justify-center">
                  #<%= value %>
                </div>
              </div>
              <div class="mt-1 text-xs text-gray-600 dark:text-gray-400 font-medium">
                <%= rank.to_s.titleize.length > 5 ? "#{rank.to_s.titleize[0..4]}..." : rank.to_s.titleize %>
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
