<%# locals: showcase:, popular_novelty_ids:, top_fiction_ids:, latest_update_ids: %>
<% carousel_nav_visible = showcase.many? %>
<section class="relative overflow-hidden mt-8 mb-4 rounded-xl shadow-xl border border-gray-200 dark:border-gray-700 hover:shadow-2xl transition-shadow duration-500">
  <div class="mx-auto max-w-screen-2xl">
    <div data-controller="custom-carousel" class="relative w-full overflow-hidden h-[calc(16rem+1em)] md:h-[calc(24rem+1em)]">
      <!-- Spinner overlay -->
      <div data-custom-carousel-target="spinner" class="absolute inset-0 flex items-center justify-center bg-black/80 z-40">
        <svg class="animate-spin h-8 w-8 text-gray-500 dark:text-gray-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      </div>
      <div data-custom-carousel-target="slides" class="flex transition-transform duration-700 ease-in-out w-full h-[calc(16rem+1em)] sm:h-[calc(24rem+1em)]" style="transform: translateX(0);">
        <% showcase.each do |fiction| %>
          <div class="min-w-full flex-shrink-0 relative h-[calc(16rem+1em)] md:h-[calc(24rem+1em)] overflow-hidden rounded-xl">
            <div
              data-controller="lazy-bg"
              data-lazy-bg-id-value="<%= fiction.id %>"
              data-lazy-bg-url-value="<%= url_for(fiction.banner) %>"
              class="absolute left-1/2 top-1/2 block h-full w-full -translate-x-1/2 -translate-y-1/2 bg-cover bg-center bg-no-repeat rounded-xl"
              id="lazy-bg-<%= fiction.id %>"
              style="background-image: none;"
            >
              <div class="absolute inset-0 bg-black/80 sm:bg-transparent sm:bg-gradient-to-r sm:from-black/80 sm:via-black/70 sm:to-black/15 sm:from-0% sm:via-40% md:to-80% transition-opacity duration-700 ease-in-out"></div>
              <div class="absolute left-0 top-1/2 z-10 min-w-0 -translate-y-1/2 px-4 md:px-12 w-full max-w-[min(30rem,calc(100%-2rem))] md:max-w-[min(40rem,calc(100%-3rem))] lg:max-w-[min(60rem,calc(100%-3rem))] transition-all duration-700 ease-in-out">
                <div class="flex flex-wrap items-center gap-2 mb-4">
                  <% if fiction.adult_content? %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-red-600 px-2.5 py-1 text-xs md:text-sm font-bold text-white shadow-md ring-1 ring-red-800/80 dark:bg-red-700 dark:ring-red-900">
                      <svg class="h-3.5 w-3.5 shrink-0 opacity-95" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                      </svg>
                      18+
                    </span>
                  <% end %>
                  <% if top_fiction_ids.include?(fiction.id) %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-cyan-950/95 px-2.5 py-1 text-xs md:text-sm font-bold text-white shadow-md ring-1 ring-cyan-800/60 dark:bg-teal-950/95 dark:ring-teal-800/60">
                      <svg class="h-3.5 w-3.5 shrink-0 opacity-95" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12"/>
                      </svg>
                      Популярне
                    </span>
                  <% end %>
                  <span class="inline-flex items-center gap-1 rounded-full bg-amber-950/90 px-2.5 py-1 text-xs md:text-sm font-bold text-amber-100 shadow-md ring-1 ring-amber-900/50 dark:bg-amber-950/90 dark:text-amber-50">
                    <svg class="h-3.5 w-3.5 shrink-0 opacity-95" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <%= Fiction.statuses[fiction.status] %>
                  </span>
                  <% if popular_novelty_ids.include?(fiction.id) %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-cyan-800/95 px-2.5 py-1 text-xs md:text-sm font-bold text-white shadow-md ring-1 ring-cyan-900/50 dark:bg-rose-800/95 dark:ring-rose-900/50">
                      <svg class="h-3.5 w-3.5 shrink-0 opacity-95" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                      </svg>
                      Новинка
                    </span>
                  <% end %>
                  <% if latest_update_ids.include?(fiction.id) %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-cyan-800/95 px-2.5 py-1 text-xs md:text-sm font-bold text-white shadow-md ring-1 ring-cyan-900/50 dark:bg-rose-800/95 dark:ring-rose-900/50">
                      <svg class="h-3.5 w-3.5 shrink-0 opacity-95" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                      </svg>
                      Оновлення
                    </span>
                  <% end %>
                </div>

                <%= tag.h2 class: "mb-2 md:mb-4 text-lg md:text-4xl font-extrabold tracking-tight leading-tight text-white drop-shadow-lg lg:text-5xl line-clamp-1" do %>
                  <%= link_to fiction.title, fiction, class: "hover:text-cyan-200 dark:hover:text-rose-200 transition-colors" %>
                <% end %>
                <%= tag.p fiction.description, class: "text-xs md:text-sm lg:text-base mb-3 font-medium text-gray-100 drop-shadow-md tracking-tight line-clamp-2 md:line-clamp-3" %>

                <div class="mb-4 md:mb-8 flex flex-wrap items-center gap-x-3 gap-y-1.5 text-sm md:text-base text-white/90">
                  <span class="inline-flex items-center gap-1 font-semibold text-amber-400 drop-shadow-sm" title="Середня оцінка">
                    <svg class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    <%= fiction.average_rating.positive? ? number_with_precision(fiction.average_rating, precision: 1) : '—' %>
                  </span>
                  <span class="inline-flex items-center gap-1.5 text-white/85" title="Перегляди">
                    <svg class="h-4 w-4 shrink-0 text-white/70" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" d="M21 12c0 1.2-4.03 6-9 6s-9-4.8-9-6c0-1.2 4.03-6 9-6s9 4.8 9 6Z"/>
                      <path stroke-linecap="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                    </svg>
                    <%= format_view_count(fiction.views) %>
                  </span>
                  <span class="inline-flex items-center gap-1.5 min-w-0 text-white/85" title="Автор">
                    <svg class="h-4 w-4 shrink-0 text-white/70" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    <span class="truncate max-w-[10rem] sm:max-w-[14rem]"><%= fiction.author %></span>
                  </span>
                </div>

                <div class="flex flex-wrap items-center gap-3">
                  <% first_readable_chapter = ordered_chapters(fiction, viewer: current_user).first %>
                  <%= link_to (first_readable_chapter ? chapter_path(first_readable_chapter) : fiction_path(fiction)), class: 'inline-flex items-center gap-2 rounded-xl bg-cyan-600 px-2 py-1.5 md:px-4 md:py-2.5 text-xs md:text-sm font-bold text-white shadow-lg ring-1 ring-cyan-500/30 hover:bg-cyan-500 focus:outline-none focus:ring-4 focus:ring-cyan-300/40 transition dark:bg-rose-600 dark:hover:bg-rose-500 dark:ring-rose-500/30 dark:focus:ring-rose-300/30 lg:text-lg', data: { turbo: false } do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
                    </svg>
                    Читати зараз
                  <% end %>
                  <%= link_to fiction_path(fiction), class: 'inline-flex items-center justify-center rounded-xl border border-white/35 bg-white/5 px-2 py-1.5 md:px-4 md:py-2.5 text-xs md:text-sm font-bold text-white backdrop-blur-sm hover:bg-white/15 focus:outline-none focus:ring-2 focus:ring-white/40 transition lg:text-lg' do %>
                    Детальніше
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      <% if carousel_nav_visible %>
        <div class="absolute bottom-3 left-1/2 z-30 flex -translate-x-1/2 items-center gap-2">
          <% showcase.each_with_index do |_fiction, idx| %>
            <button
              type="button"
              data-custom-carousel-target="indicator"
              data-action="custom-carousel#goTo"
              data-index="<%= idx %>"
              class="carousel-indicator shrink-0 h-2.5 w-2.5 rounded-full bg-white/35 transition-all duration-300 hover:bg-white/55 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/70"
            ></button>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>
