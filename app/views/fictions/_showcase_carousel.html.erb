<%# locals: showcase:, popular_novelty_ids:, top_fiction_ids:, latest_update_ids: %>
<% carousel_nav_visible = showcase.many? %>
<% first_fiction = showcase.first %>
<% first_banner_url = first_fiction && banner_showcase_url(first_fiction.banner) %>
<% eager_first_slide = first_banner_url.present? %>
<% if eager_first_slide %>
  <% content_for :head do %>
    <%= tag.link rel: "preload", as: "image", href: first_banner_url, fetchpriority: "high" %>
  <% end %>
<% end %>
<section class="relative overflow-hidden mt-8 mb-4 rounded-2xl shadow-xl border border-gray-200 dark:border-gray-700 hover:shadow-2xl transition-shadow duration-500">
  <div class="mx-auto max-w-screen-2xl">
    <div data-controller="custom-carousel"
         <% if eager_first_slide %> data-custom-carousel-eager-first-slide-value="true" <% end %>
         class="relative w-full overflow-hidden h-[calc(16rem+1em)] md:h-[calc(24rem+1em)]">
      <!-- Spinner overlay -->
      <div data-custom-carousel-target="spinner" class="absolute inset-0 flex items-center justify-center bg-black/80 z-40<%= ' hidden' if eager_first_slide %>">
        <svg class="animate-spin h-8 w-8 text-gray-500 dark:text-gray-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      </div>
      <div data-custom-carousel-target="slides" class="flex transition-transform duration-700 ease-in-out w-full h-[calc(16rem+1em)] sm:h-[calc(24rem+1em)]" style="transform: translateX(0);">
        <% showcase.each_with_index do |fiction, index| %>
          <% banner_url = index.zero? ? first_banner_url : banner_showcase_url(fiction.banner) %>
          <% eager_slide = index.zero? && banner_url.present? %>
          <div class="min-w-full flex-shrink-0 relative h-[calc(16rem+1em)] md:h-[calc(24rem+1em)] overflow-hidden rounded-2xl">
            <% if eager_slide %>
              <%= image_tag banner_url,
                    alt: "",
                    aria: { hidden: true },
                    fetchpriority: "high",
                    loading: "eager",
                    decoding: "async",
                    width: 1600,
                    height: 540,
                    class: "absolute left-1/2 top-1/2 block h-full w-full -translate-x-1/2 -translate-y-1/2 object-cover object-center rounded-2xl" %>
            <% else %>
              <div
                data-controller="lazy-bg"
                data-lazy-bg-id-value="<%= fiction.id %>"
                data-lazy-bg-url-value="<%= banner_url %>"
                class="absolute left-1/2 top-1/2 block h-full w-full -translate-x-1/2 -translate-y-1/2 bg-cover bg-center bg-no-repeat rounded-2xl"
                id="lazy-bg-<%= fiction.id %>"
                style="background-image: none;"></div>
            <% end %>
            <div class="absolute inset-0 bg-black/80 sm:bg-transparent sm:bg-gradient-to-r sm:from-black/80 sm:via-black/70 sm:to-black/15 sm:from-0% sm:via-40% md:to-80% transition-opacity duration-700 ease-in-out"></div>
            <div class="absolute left-0 top-1/2 z-10 min-w-0 -translate-y-1/2 px-4 md:px-12 w-full max-w-[min(30rem,calc(100%-2rem))] md:max-w-[min(40rem,calc(100%-3rem))] lg:max-w-[min(50rem,calc(100%-3rem))] transition-all duration-700 ease-in-out">
              <%= render Ui::EditorialTagListComponent.new(
                    kinds: Fictions::HeroEditorialTags.new(
                      fiction,
                      popular_novelty_ids: popular_novelty_ids,
                      top_fiction_ids: top_fiction_ids,
                      latest_update_ids: latest_update_ids
                    ).call,
                    html: { class: 'mb-4' }
                  ) %>

              <%= tag.h2 class: "mb-2 md:mb-4 text-2xl md:text-4xl font-extrabold tracking-tight leading-tight text-white drop-shadow-lg lg:text-5xl line-clamp-1" do %>
                <%= link_to fiction.title, fiction, class: "hover:text-cyan-200 dark:hover:text-rose-200 transition-colors" %>
              <% end %>

              <div class="mb-4 md:mb-8 flex flex-col gap-4">
                <%= tag.p fiction.description, class: "text-sm md:text-base font-medium leading-snug text-white/90 drop-shadow-md tracking-tight line-clamp-2 md:line-clamp-3" %>

                <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5 text-sm md:text-base text-white/90">
                  <span class="inline-flex items-center gap-1 font-semibold text-amber-400 drop-shadow-sm" title="Середня оцінка">
                    <svg class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                    <%= fiction.average_rating.positive? ? number_with_precision(fiction.average_rating, precision: 1) : '—' %>
                  </span>
                  <span class="inline-flex items-center gap-1.5 text-white/85" title="Перегляди">
                    <svg class="h-4 w-4 shrink-0 text-white/70" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" d="M21 12c0 1.2-4.03 6-9 6s-9-4.8-9-6c0-1.2 4.03-6 9-6s9 4.8 9 6Z" />
                      <path stroke-linecap="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    </svg>
                    <%= format_view_count(fiction.views) %>
                  </span>
                  <span class="inline-flex items-center gap-1.5 min-w-0 text-white/85" title="Автор">
                    <svg class="h-4 w-4 shrink-0 text-white/70" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                    <span class="truncate max-w-[10rem] sm:max-w-[14rem]"><%= fiction.author %></span>
                  </span>
                </div>
              </div>

              <div class="flex flex-wrap items-center gap-3">
                <% first_readable_chapter = ordered_chapters(fiction, viewer: current_user).first %>
                <%= ui_button(as: :link,
                              href: (first_readable_chapter ? chapter_path(first_readable_chapter) : fiction_path(fiction)),
                              size: :md,
                              html: { data: { turbo: false } }) do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z" />
                  </svg>
                  Читати зараз
                <% end %>
                <%= ui_button(as: :link,
                              href: fiction_path(fiction),
                              variant: :ghost,
                              size: :md,
                              html: { class: 'shrink-0 !border-white/50 !bg-transparent !text-white hover:!border-white hover:!bg-white/10 hover:!text-white dark:!border-white/40 dark:!bg-transparent dark:!text-white dark:hover:!border-white/70 dark:hover:!bg-white/10', aria: { label: 'Детальніше' } }) do %>
                  <svg class="h-5 w-5 shrink-0 lg:hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                  <span class="hidden lg:inline">Детальніше</span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      <% if carousel_nav_visible %>
        <div class="absolute bottom-3 left-1/2 z-30 flex -translate-x-1/2 items-center gap-2" role="group" aria-label="Навігація по слайдах вітрини">
          <% showcase.each_with_index do |fiction, idx| %>
            <button
              type="button"
              data-custom-carousel-target="indicator"
              data-action="custom-carousel#goTo"
              data-index="<%= idx %>"
              aria-label="Перейти до слайду <%= idx + 1 %> з <%= showcase.size %>: <%= fiction.title %>"
              <% if idx.zero? %> aria-current="true"<% end %>
              class="carousel-indicator shrink-0 h-1.5 w-3.5 rounded-lg bg-white/35 transition-all duration-300 hover:bg-white/55 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/70"></button>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>
