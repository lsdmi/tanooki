<%# locals: reader_gate: false (optional) %>
<% reader_gate = local_assigns.fetch(:reader_gate, false) %>
<section
  role="alert"
  aria-label="<%= t('fictions.adult_content_disclaimer.aria_label') %>"
  data-adult-content-disclaimer
  data-controller="adult-content-disclaimer"
  class="adult-content-disclaimer mb-4 rounded-2xl bg-[#ff4d4f] px-4 py-3 text-white shadow-[0_1px_2px_rgb(0_0_0/0.06),0_4px_14px_rgb(220_38_38/0.28)] dark:bg-[#c42f31] dark:shadow-[0_1px_2px_rgb(0_0_0/0.22),0_4px_16px_rgb(0_0_0/0.38)] sm:mb-6 sm:px-5 sm:py-3.5">
  <div class="pointer-events-none absolute inset-0 overflow-hidden rounded-2xl" aria-hidden="true">
    <svg class="adult-content-disclaimer__circle adult-content-disclaimer__circle--left" viewBox="0 0 160 160" xmlns="http://www.w3.org/2000/svg">
      <circle cx="80" cy="80" r="80" class="adult-content-disclaimer__circle-fill" />
    </svg>
    <svg class="adult-content-disclaimer__circle adult-content-disclaimer__circle--right" viewBox="0 0 140 140" xmlns="http://www.w3.org/2000/svg">
      <circle cx="70" cy="70" r="70" class="adult-content-disclaimer__circle-fill" />
    </svg>
  </div>

  <div class="relative z-[1] flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-4">
    <div class="flex min-w-0 flex-1 items-center gap-3 sm:gap-4">
      <div class="adult-content-disclaimer__icon flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-white dark:bg-zinc-100" aria-hidden="true">
        <svg class="h-6 w-6 text-[#d93c3e] dark:text-[#b83234]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
      </div>
      <div class="min-w-0">
        <p class="text-[15px] font-bold leading-snug sm:text-base">
          <%= t(reader_gate ? 'fictions.adult_content_disclaimer.reader_title' : 'fictions.adult_content_disclaimer.title') %>
        </p>
        <p class="mt-0.5 text-xs leading-relaxed text-white/95 sm:text-sm">
          <%= t('fictions.adult_content_disclaimer.description') %>
        </p>
      </div>
    </div>

    <button
      type="button"
      data-action="adult-content-disclaimer#dismiss"
      class="adult-content-disclaimer__dismiss w-full shrink-0 rounded-lg bg-white px-5 py-2 text-sm font-bold text-stone-900 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-[#ff4d4f] dark:bg-zinc-100 dark:text-stone-900 dark:hover:bg-white dark:focus-visible:ring-offset-[#c42f31] sm:w-auto sm:self-center">
      <%= t('fictions.adult_content_disclaimer.dismiss') %>
    </button>
  </div>
</section>
