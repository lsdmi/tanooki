<div id="fiction_details" data-fiction-picker-target="frame" class="grid grid-cols-3 md:grid-cols-4 lg:grid-cols-3 gap-y-4 gap-x-4 sm:gap-x-6 px-0 sm:px-2 fade-in-active dark:bg-gray-800 rounded-lg">
  <div data-controller="lazy-image" data-lazy-image-image-id="<%= fiction.id %>" class="relative sm:h-70 transition duration-300 transform hover:scale-105">
    <div id="spinner-<%= fiction.id %>" class="absolute inset-0 flex items-center justify-center bg-gray-200 dark:bg-gray-700 rounded-md">
      <svg class="animate-spin h-8 w-8 text-gray-500 dark:text-gray-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    </div>
    <%= link_to fiction_path(fiction), data: { turbo: false } do %>
      <%= image_tag url_for(fiction.cover),
        alt: fiction.cover.blob.filename.to_s,
        id: "image-#{fiction.id}",
        class: "w-full h-full object-cover rounded-md shadow-sm opacity-0",
        loading: "lazy",
        data: { url: url_for(fiction.cover) } %>
    <% end %>
  </div>

  <div class="col-span-2 md:col-span-3 lg:col-span-2 my-1">
    <div>
      <%= link_to fiction_path(fiction), data: { turbo: false }, class: 'group' do %>
        <h3 class="text-sm sm:text-2xl font-semibold text-stone-800 dark:text-gray-200 line-clamp-1 group-hover:text-cyan-700 dark:group-hover:text-rose-700 transition-colors duration-300">
          <%= fiction.title %>
        </h3>
      <% end %>

        <% if fiction.genres.any? %>
          <%= render Ui::TagListComponent.new(
                labels: fiction.genres.map(&:name),
                variant: :genre,
                size: :sm,
                max: 2,
                sort_adult_first: true,
                genre_slugs: fiction.genres.to_h { |genre| [genre.name, genre.slug] },
                href_builder: ->(name) {
                  fiction_genre_fictions_path(fiction.genres.find { |genre| genre.name == name })
                },
                html: { class: 'text-xs flex flex-wrap gap-2 mt-2' },
                tag_html: { data: { turbo: false } }
              ) %>
        <% end %>
    </div>

    <p class="text-stone-700 dark:text-gray-300 text-xs sm:text-sm line-clamp-4 sm:line-clamp-6 whitespace-break-spaces my-2 sm:my-4"><%= fiction.description %></p>

    <%= ui_button(as: :link,
                  href: fiction_path(fiction),
                  size: :responsive,
                  html: { data: { turbo: false } }) do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="hidden h-4 w-4 sm:block md:h-5 md:w-5 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z" />
      </svg>
      <span>Читати</span>
    <% end %>
  </div>
</div>
