<% scanlators_with_notice = fiction.scanlators.select { |s| s.notice.present? } %>
<% if scanlators_with_notice.any? %>
  <% scanlator = scanlators_with_notice.sample %>
  <section class="bg-gradient-to-br from-amber-50/90 to-stone-100 dark:from-gray-800 dark:to-gray-700 rounded-lg shadow-md p-4 sm:p-6 border border-stone-200 dark:border-gray-700 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-20 h-20 bg-amber-200/40 dark:bg-gray-600 rounded-full transform translate-x-1/3 -translate-y-1/3 opacity-50"></div>

    <div class="relative z-10 flex flex-col gap-2 pb-3 sm:flex-row sm:items-center sm:justify-between sm:gap-3 sm:pb-4">
      <div class="flex min-w-0 flex-1 items-center gap-2.5 overflow-hidden">
        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-amber-200/80 text-amber-950 dark:bg-amber-950/35 dark:text-amber-300 sm:h-10 sm:w-10">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M7.556 8.5h8m-8 3.5H12m7.111-7H4.89a.896.896 0 0 0-.629.256.868.868 0 0 0-.26.619v9.25c0 .232.094.455.26.619A.896.896 0 0 0 4.89 16H9l3 4 3-4h4.111a.896.896 0 0 0 .629-.256.868.868 0 0 0 .26-.619v-9.25a.868.868 0 0 0-.26-.619.896.896 0 0 0-.63-.256Z" />
          </svg>
        </span>
        <h4 class="shrink-0 text-lg font-bold text-stone-800 dark:text-gray-200 sm:text-xl">Оголошення</h4>
      </div>
      <%= link_to scanlator_path(scanlator), class: 'block min-w-0 max-w-full truncate text-left text-xs font-semibold text-stone-700 dark:text-gray-300 hover:text-amber-800 dark:hover:text-amber-300 sm:max-w-[min(50%,14rem)] sm:flex-none sm:text-right sm:text-sm transition duration-200' do %>
        <%= scanlator.title %>
      <% end %>
    </div>

    <div class="relative z-10">
      <p class="text-sm sm:text-base text-stone-600 dark:text-gray-300 leading-relaxed whitespace-pre-line"><%= linkify_urls(scanlator.notice, link_class: 'underline font-medium text-amber-700 dark:text-amber-400 hover:text-amber-900 dark:hover:text-amber-300 break-words') %></p>
    </div>
  </section>
<% end %>
