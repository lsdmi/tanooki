<%= turbo_frame_tag 'fiction_sidebar_stats' do %>
  <% if @show_presenter.monthly_reads_stats? %>
    <%= render 'sidebar_monthly_reads', show_presenter: @show_presenter %>
  <% end %>
  <% if @show_presenter.ranks.any? %>
    <%= render 'sidebar_ranks', show_presenter: @show_presenter %>
  <% end %>
<% end %>
