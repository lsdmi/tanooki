<li class="group">
  <div class="p-3 hover:bg-stone-50 dark:hover:bg-gray-700 transition duration-150 ease-in-out">
    <%= link_to chapter_path(chapter), data: { turbo: false }, class: 'block' do %>
      <div class="flex items-center justify-between gap-4">
        <div class="flex items-center gap-3 min-w-0 flex-1">
          <span class="mt-2 flex-shrink-0 w-6 h-6 bg-stone-200 dark:bg-gray-600 text-stone-600 dark:text-gray-300 rounded-full flex items-center justify-center text-xs font-medium">
            <%= chapter.number %>
          </span>
          <div class="min-w-0 flex-1">
            <span class="block text-stone-700 dark:text-gray-300 group-hover:text-stone-900 dark:group-hover:text-gray-100 truncate">
              <%= chapter.display_title_no_volume %>
            </span>
          </div>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <span class="text-xs text-stone-500 dark:text-gray-400 whitespace-nowrap">
            <%= l(chapter.public_at, format: :shortest).downcase %>
          </span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-stone-400 dark:text-gray-500 group-hover:text-stone-600 dark:group-hover:text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      </div>
    <% end %>
    <% if chapter.scanlators.any? %>
      <div class="pl-9">
        <p class="text-[0.65rem] leading-snug text-stone-500 dark:text-gray-500">
          <%= safe_join(
                chapter.scanlators.map { |scanlator|
                  link_to(
                    scanlator.title,
                    scanlator_path(scanlator),
                    class: 'text-stone-500 dark:text-gray-500 hover:text-stone-800 dark:hover:text-gray-300 underline-offset-2 hover:underline',
                    data: { turbo: false }
                  )
                },
                ', '
              ) %>
        </p>
      </div>
    <% end %>
  </div>
</li>
