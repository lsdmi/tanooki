<%# locals: chapter:, compact: false (optional) %>
<% compact = local_assigns.fetch(:compact, false) %>
<li class="group <%= compact ? 'list-none' : '' %>">
  <% if compact %>
    <div>
      <% compact_scanlators = chapter.scanlators.any? %>
      <%= link_to chapter_path(chapter), data: { turbo: false }, class: "flex items-center justify-between gap-3 px-4 #{compact_scanlators ? 'pt-3.5 pb-1' : 'py-3.5'}" do %>
        <span class="min-w-0 flex-1 truncate text-left text-sm font-normal leading-tight text-stone-800 underline-offset-2 decoration-stone-700/80 hover:underline dark:text-white dark:decoration-white/70">
          <%= chapter.display_title_no_volume %>
        </span>
        <div class="flex shrink-0 items-center gap-2">
          <span class="whitespace-nowrap text-xs text-stone-500 dark:text-zinc-500"><%= l(chapter.public_at, format: :shortest).downcase %></span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-stone-400 dark:text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      <% end %>
      <% if compact_scanlators %>
        <div class="-mt-1 px-4 pb-2">
          <p class="text-[0.65rem] leading-tight text-stone-600 dark:text-zinc-500">
            <%= safe_join(
                  chapter.scanlators.map { |scanlator|
                    link_to(
                      scanlator.title,
                      scanlator_path(scanlator),
                      class: "text-stone-700 underline-offset-2 hover:text-stone-900 hover:underline dark:text-zinc-400 dark:hover:text-zinc-300",
                      data: { turbo: false }
                    )
                  },
                  ', '
                ) %>
          </p>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="p-3 transition duration-150 ease-in-out hover:bg-stone-50 dark:hover:bg-gray-700">
      <%= link_to chapter_path(chapter), data: { turbo: false }, class: "block" do %>
        <div class="flex items-center justify-between gap-4">
          <div class="flex min-w-0 flex-1 items-center gap-3">
            <span class="mt-2 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-stone-200 text-xs font-medium text-stone-600 dark:bg-gray-600 dark:text-gray-300">
              <%= chapter.number %>
            </span>
            <div class="min-w-0 flex-1">
              <span class="block truncate text-stone-700 group-hover:text-stone-900 dark:text-gray-300 dark:group-hover:text-gray-100">
                <%= chapter.display_title_no_volume %>
              </span>
            </div>
          </div>
          <div class="flex shrink-0 items-center gap-2">
            <span class="whitespace-nowrap text-xs text-stone-500 dark:text-gray-400">
              <%= l(chapter.public_at, format: :shortest).downcase %>
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-stone-400 group-hover:text-stone-600 dark:text-gray-500 dark:group-hover:text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </div>
      <% end %>
      <% if chapter.scanlators.any? %>
        <div class="-mt-1 pl-9">
          <p class="text-[0.65rem] leading-snug text-stone-500 dark:text-gray-500">
            <%= safe_join(
                  chapter.scanlators.map { |scanlator|
                    link_to(
                      scanlator.title,
                      scanlator_path(scanlator),
                      class: "text-stone-500 underline-offset-2 hover:text-stone-800 hover:underline dark:text-gray-500 dark:hover:text-gray-300",
                      data: { turbo: false }
                    )
                  },
                  ', '
                ) %>
          </p>
        </div>
      <% end %>
    </div>
  <% end %>
</li>
