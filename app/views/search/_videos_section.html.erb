<%= turbo_frame_tag 'videos-section' do %>
  <div class="bg-white/80 dark:bg-gray-800/80 backdrop-filter backdrop-blur-xl rounded-2xl shadow-2xl p-6 relative overflow-hidden mb-8">
    <div class="absolute inset-0 z-0 opacity-5">
      <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
        <pattern id="video-pattern" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M0 0h40v40H0z" fill="none" />
          <path d="M0 20h40M20 0v40" stroke="currentColor" stroke-width="0.5" />
          <circle cx="20" cy="20" r="1" fill="currentColor" />
        </pattern>
        <rect width="100%" height="100%" fill="url(#video-pattern)" />
      </svg>
    </div>

    <div class="relative z-10">
    <div class="flex items-center mb-6">
      <div class="h-8 w-8 rounded-lg bg-red-100 dark:bg-red-900/20 flex items-center justify-center mr-3">
        <svg class="h-4 w-4 text-red-600/80 dark:text-red-400/80" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
      </div>
      <h2 class="text-2xl font-extrabold text-gray-700 dark:text-gray-200">Відео</h2>
      <span class="ml-3 px-2 py-1 bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-300 text-sm font-semibold rounded">
        <%= defined?(pagy_videos) && pagy_videos ? pagy_videos.count : videos.count %>
      </span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <% videos.each do |video| %>
        <article class="group">
          <%= link_to youtube_video_path(video), class: 'block', data: { turbo: false } do %>
            <div class="relative w-full overflow-hidden rounded-lg aspect-video mb-3">
              <%= tag.iframe src: "https://www.youtube.com/embed/#{video.video_id}",
                class: 'absolute inset-0 h-full w-full rounded-lg',
                allowfullscreen: true,
                title: video.title %>
            </div>
            <%= tag.h3 video.title,
              class: 'text-base font-semibold text-gray-900 dark:text-gray-100 line-clamp-2 group-hover:text-cyan-700 dark:group-hover:text-rose-700 transition-colors duration-300' %>
          <% end %>
        </article>
      <% end %>
    </div>

    <!-- Video Pagination -->
    <% if defined?(pagy_videos) && pagy_videos %>
      <%= ui_pagination(
            pagy_videos,
            frame_id: 'videos-section',
            custom_params: search_index_pagy_custom_params('videos'),
            html: { class: 'mt-8' }
          ) %>
    <% end %>
    </div>
  </div>
<% end %>
