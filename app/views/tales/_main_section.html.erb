<% main_highlight = highlights.first %>
<div class="lg:pt-2 lg:mb-3 flex flex-col md:flex-row lg:flex-col md:gap-4">
  <div class="relative w-full md:w-2/5 lg:w-full shrink-0 overflow-hidden rounded-md h-48 md:h-48 lg:h-72 mb-2 lg:mb-2">
    <%= link_to tale_path(main_highlight), class: "block h-full w-full" do %>
      <%= image_tag url_for(main_highlight.cover), alt: main_highlight.cover.blob.filename.to_s, class: "h-full w-full object-cover rounded-md opacity-80 lg:object-fill", loading: 'eager' %>
      <div class="absolute inset-0 rounded-md opacity-0 hover:opacity-100 transition duration-300 ease-in-out" style="background-color: rgba(255, 255, 255, 0.2)"></div>
    <% end %>
  </div>
  <div class="w-full md:flex-1 md:min-w-0 lg:border-b-4 border-purple-300 lg:mb-4">
    <%= render Ui::TagListComponent.new(
          labels: main_highlight.tags.map(&:name),
          variant: :keyword,
          size: :md,
          max: 3,
          href_builder: ->(name) { search_index_path(search: [name]) },
          counts: publication_tag_counts,
          html: { class: 'mb-1' }
        ) %>
    <h2 class="my-2 text-2xl md:text-2xl lg:text-3xl font-bold tracking-tight text-gray-900 dark:text-gray-100 hover:underline">
      <%= link_to main_highlight.title, tale_path(main_highlight) %>
    </h2>
    <%= tag.p main_highlight.description.to_plain_text, class: 'mb-4 mt-2 font-light text-gray-500 dark:text-gray-400 line-clamp-2 md:line-clamp-3 lg:line-clamp-2 lg:leading-6' %>
  </div>
</div>
<div class="relative w-full mt-0">
  <% highlights.excluding(main_highlight).each do |publication| %>
    <%= render 'responsive_tile', publication:, publication_tag_counts: %>
  <% end %>
</div>
