<div class="mx-auto w-full max-w-screen-xl px-4 py-6 2xl:px-0">
  <header class="mb-6">
    <h1 class="text-xl font-semibold uppercase tracking-tight text-gray-900 dark:text-gray-100 sm:text-2xl">
      Новини та <span class="text-cyan-700 dark:text-rose-700">блоги</span>
    </h1>
  </header>

  <%= render 'publication_tiles', publications: @highlights, publication_tag_counts: @publication_tag_counts %>

  <% if @advertisement.present? %>
    <div class="py-6">
      <%= render 'shared/ads', advertisement: @advertisement %>
    </div>
  <% end %>

  <section class="<%= 'border-t border-stone-200/70 dark:border-gray-700/50 pt-1' if @highlights.any? %>">
    <%= render 'publication_tiles', publications: @publications, publication_tag_counts: @publication_tag_counts %>
    <%= render 'home/next_page', pagy: @pagy %>
  </section>
</div>
