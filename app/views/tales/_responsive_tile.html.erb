<div class="mt-2 lg:mt-0 relative w-full mb-1 lg:mb-2 flex flex-col md:flex-row lg:flex-col md:gap-4 md:items-start">
  <div class="relative w-full md:w-2/5 lg:w-full shrink-0 overflow-hidden rounded-xl h-48 md:h-44 lg:h-36">
    <%= link_to tale_path(publication), class: "block h-full w-full" do %>
      <%= image_tag cover_card_url(publication.cover), alt: publication.cover.blob.filename.to_s, class: "h-full w-full object-cover rounded-xl opacity-80", width: 320, height: 192 %>
      <div class="absolute inset-0 rounded-xl opacity-0 hover:opacity-100 transition duration-300 ease-in-out" style="background-color: rgba(255, 255, 255, 0.2)"></div>
    <% end %>
  </div>
  <div class="w-full md:flex-1 md:min-w-0">
    <div class="rounded-xl mb-1 text-gray-500 dark:text-gray-400">
      <div class="sm:mb-1 lg:mb-0">
        <%= render Ui::TagListComponent.new(
              labels: publication.tags.map(&:name),
              variant: :keyword,
              size: :sm,
              max: 3,
              href_builder: ->(name) { search_index_path(search: [name]) },
              counts: publication_tag_counts
            ) %>
      </div>
      <h2 class="mt-2 mb-1 text-2xl lg:text-xl font-bold tracking-tight text-gray-900 dark:text-gray-100 hover:underline line-clamp-2">
        <%= link_to publication.title, tale_path(publication) %>
      </h2>
      <%= tag.p publication.description.to_plain_text, class: 'text-base lg:text-sm font-light text-gray-500 dark:text-gray-400 line-clamp-2 md:line-clamp-3 lg:line-clamp-2 mt-2 lg:mt-1 lg:leading-6' %>
    </div>
  </div>
</div>
