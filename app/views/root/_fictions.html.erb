<%# locals: fictions: %>
<%# Card widths show a sliver of the next item so horizontal scroll is obvious (lg: 4 full + 80% of 5th). %>
<%# Break out of the page gutter on the right so the trailing card bleeds off the screen edge. %>
<div
  class="flex snap-x snap-mandatory gap-4 overflow-x-auto overscroll-x-contain [-webkit-overflow-scrolling:touch] lg:snap-proximity -mr-4 md:-mr-6 lg:mr-0"
  role="region"
  aria-label="Популярне ранобе">
  <% fictions.each do |fiction| %>
    <% card = popular_fiction_card_stats(fiction) %>
    <article class="group w-[calc((100%-32px)/2.5)] shrink-0 snap-start sm:w-[calc((100%-16px)/2.15)] md:w-[calc((100%-48px)/3.2)] lg:w-[calc((100%-64px)/4.8)]">
      <%= link_to fiction_path(fiction), turbo_drive_visit_data.merge(class: 'relative block aspect-[2/3] overflow-hidden rounded-xl bg-stone-200 transition-[filter,transform] duration-300 ease-out focus:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-violet-500 group-hover:brightness-105 dark:bg-slate-800 dark:focus-visible:ring-violet-400') do %>
        <%= image_tag cover_card_url(fiction.cover),
                      alt: fiction.title,
                      class: 'absolute inset-0 h-full w-full object-cover object-center transition-transform duration-300 ease-out group-hover:scale-[1.03]',
                      loading: 'lazy' %>
        <div class="pointer-events-none absolute inset-x-0 bottom-0 z-10 flex items-end justify-between gap-3 bg-gradient-to-t from-black/80 via-black/40 to-transparent px-3 pb-3 pt-10">
          <%= render Ui::GenrePageTagComponent.new(variant: :stat_views, label: card[:views]) %>
          <%= render Ui::GenrePageTagComponent.new(variant: :stat_rating, label: card[:rating]) %>
        </div>
      <% end %>
      <div class="pb-2 pt-3">
        <p class="text-sm font-semibold leading-tight text-stone-900 dark:text-slate-100 lg:text-base">
          <%= link_to fiction.title,
                      fiction_path(fiction),
                      turbo_drive_visit_data.merge(class: 'line-clamp-1 rounded-lg transition-colors hover:text-cyan-700 hover:underline underline-offset-2 dark:hover:text-rose-400 group-hover:text-cyan-700 dark:group-hover:text-rose-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-violet-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-gray-900') %>
        </p>
        <% if card[:genres].present? %>
          <p class="mt-1 line-clamp-1 text-[10px] font-normal text-stone-600 dark:text-slate-400 lg:text-xs">
            <% card[:genres].each_with_index do |genre, index| %>
              <% if index.positive? %><span aria-hidden="true"> </span><% end %>
              <%= link_to genre[:name],
                          fiction_genre_fictions_path(genre[:slug]),
                          turbo_drive_visit_data.merge(class: 'transition-colors hover:text-cyan-700 hover:underline dark:hover:text-rose-400') %>
            <% end %>
          </p>
        <% end %>
      </div>
    </article>
  <% end %>
</div>
