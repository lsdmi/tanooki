<%# locals: (video:) %>
<div class="relative aspect-video w-full overflow-hidden rounded-xl bg-gray-800 lg:aspect-auto lg:h-full lg:min-h-0">
  <%= tag.iframe src: "https://www.youtube.com/embed/#{video.video_id}",
                 class: 'absolute inset-0 h-full w-full rounded-xl',
                 allowfullscreen: true,
                 title: video.title %>
</div>
