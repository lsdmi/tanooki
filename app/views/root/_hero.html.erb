<% content_for :head do %>
  <%= tag.link rel: 'preload', as: 'image', href: asset_path('banner/banner_mobile_tall.webp'), fetchpriority: 'high', media: '(max-width: 767px)' %>
  <%= tag.link rel: 'preload', as: 'image', href: asset_path('banner/banner_desktop.webp'), fetchpriority: 'high', media: '(min-width: 768px)' %>
<% end %>

<% hero_ghost_button_classes = '!border-white/60 !bg-transparent !text-white hover:!border-white hover:!bg-white/10 hover:!text-white dark:!border-white/50 dark:!bg-transparent dark:!text-white dark:hover:!border-white/70 dark:hover:!bg-white/10' %>

<section class="relative overflow-hidden rounded-xl md:rounded-2xl aspect-[1474/1407] md:aspect-auto">
  <picture class="absolute inset-0">
    <source media="(min-width: 768px)" srcset="<%= asset_path('banner/banner_desktop.webp') %>">
    <%= image_tag 'banner/banner_mobile_tall.webp',
                  alt: '',
                  aria: { hidden: true },
                  fetchpriority: 'high',
                  loading: 'eager',
                  decoding: 'async',
                  width: 1474,
                  height: 1407,
                  class: 'h-full w-full object-cover object-center md:object-[72%_center]' %>
  </picture>

  <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/40 to-black/15 md:from-black/55 md:via-black/25 md:to-transparent" aria-hidden="true"></div>

  <div class="relative z-10 flex h-full items-end px-4 pb-5 md:block md:h-auto md:px-12 md:py-20">
    <div class="max-w-md md:max-w-xl text-white">
      <% if user_signed_in? %>
        <h1 class="mb-2 text-3xl font-extrabold leading-tight tracking-tight md:mb-4 md:text-5xl md:leading-tight">
          Ласкаво просимо<br>
          до нашої <span class="text-cyan-400 dark:text-rose-500">Бібліярні</span>
        </h1>
        <p class="mb-4 text-sm font-light leading-relaxed text-gray-200 md:mb-8 md:text-lg">
          Скарбниця огорнулася новими оповідями — озирнися, чи не чатують на тебе давні друзі? Гортай сторінки улюблених витворів або ж відшукай нові — бодай цей вечір стане сповненим дивом!
        </p>
      <% else %>
        <h1 class="mb-2 text-3xl font-extrabold leading-tight tracking-tight md:mb-4 md:text-5xl md:leading-tight">
          Найбільше джерело <span class="text-cyan-400 dark:text-rose-500">ранобе в Україні</span>
        </h1>
        <p class="mb-4 text-sm font-light leading-relaxed text-gray-200 md:mb-8 md:text-lg">
          Сотні історій рідним словом — не осягнути й за цілий вік.
          Читайте, відкривайте нове, станьте частиною братерства, для котрого оповідь — єство життя!
        </p>
      <% end %>

      <div class="flex flex-wrap items-center gap-2 md:gap-3">
        <%= ui_button(as: :link, href: fictions_path, size: :md, html: turbo_drive_visit_data) do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 md:h-5 md:w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z" />
          </svg>
          До оповідей
        <% end %>

        <% if user_signed_in? %>
          <%= ui_button(as: :link,
                        href: library_path,
                        variant: :ghost,
                        size: :md,
                        html: turbo_drive_visit_data.merge(class: hero_ghost_button_classes)) do %>
            Збережені
          <% end %>
        <% else %>
          <%= ui_button(as: :link,
                        href: new_user_session_path,
                        variant: :ghost,
                        size: :md,
                        html: turbo_drive_visit_data.merge(class: hero_ghost_button_classes)) do %>
            Увійти
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</section>
