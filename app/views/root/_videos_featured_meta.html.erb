<%# locals: (video:, video_tag_counts:) %>
<div class="min-w-0">
  <h3 class="text-xs font-semibold leading-snug sm:text-base md:text-lg lg:text-xl">
    <%= link_to video.title,
                youtube_video_path(video),
                turbo_drive_visit_data.merge(
                  class: 'line-clamp-1 rounded-lg text-stone-900 transition-colors hover:text-cyan-700 hover:underline underline-offset-2 dark:text-gray-100 dark:hover:text-rose-400'
                ) %>
  </h3>

  <% if video.tags? %>
    <% tag_list_options = {
         labels: home_video_tag_labels(video),
         variant: :keyword,
         href_builder: ->(video_tag) { search_index_path(search: [video_tag]) },
         counts: video_tag_counts
       } %>

    <%= render Ui::TagListComponent.new(
          **tag_list_options,
          size: :sm,
          max: Root::VideosHelper::NARROW_FEATURED_TAG_LIMIT,
          html: { class: 'mt-2 flex gap-1.5 sm:hidden' }
        ) %>
    <%= render Ui::TagListComponent.new(
          **tag_list_options,
          size: :sm,
          max: Root::VideosHelper::TABLET_FEATURED_TAG_LIMIT,
          html: { class: 'mt-2.5 hidden gap-2 sm:flex md:mt-3 lg:hidden' }
        ) %>
    <%= render Ui::TagListComponent.new(
          **tag_list_options,
          size: :md,
          max: Root::VideosHelper::FEATURED_TAG_LIMIT,
          html: { class: 'mt-3 hidden gap-2 lg:flex' }
        ) %>
  <% end %>
</div>
