<section class="antialiased w-full">
  <div class="max-w-screen-xl px-4 mx-auto lg:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8">
      <% videos.each do |video| %>
        <article class="overflow-hidden p-2 sm:p-4">
          <div class="rounded-xl relative w-full overflow-hidden aspect-video mb-3">
            <%= tag.iframe src: "https://www.youtube.com/embed/#{video.video_id}",
              class: 'absolute inset-0 h-full w-full rounded-xl',
              allowfullscreen: true,
              title: video.title %>
          </div>

          <div class="space-y-2">
            <%= link_to youtube_video_path(video), class: 'block' do %>
              <%= tag.h3 video.title,
                class: 'text-base sm:text-lg lg:text-xl font-semibold text-stone-800 dark:text-gray-200 line-clamp-2 hover:text-cyan-700 dark:hover:text-rose-700 transition-colors duration-300 drop-shadow' %>
            <% end %>

            <% if video.tags? %>
              <%= render Ui::TagListComponent.new(
                    labels: Search::TagCounts.labels_from_youtube_video(
                      video,
                      limit: Search::TagCounts::HOME_YOUTUBE_TAG_LIMIT
                    ),
                    variant: :keyword,
                    size: :md,
                    max: 3,
                    href_builder: ->(video_tag) { search_index_path(search: [video_tag]) },
                    counts: video_tag_counts,
                    html: { class: 'mt-2' }
                  ) %>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</section>
