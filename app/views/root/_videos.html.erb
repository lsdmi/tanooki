<%# locals: (videos:, video_tag_counts:) %>
<% editorial = home_videos_editorial_cards(videos) %>
<% return if editorial[:featured].blank? %>

<section class="mb-8 mt-8 lg:mb-14 lg:mt-14" aria-labelledby="home-videos">
  <header class="mb-6 flex items-stretch gap-3 sm:gap-4 lg:mb-8">
    <div class="w-1.5 shrink-0 rounded-lg bg-cyan-700 dark:bg-rose-500" aria-hidden="true"></div>
    <div class="flex min-w-0 flex-1 items-center justify-between gap-4">
      <h2 id="home-videos" class="text-xl font-bold leading-snug tracking-tight text-stone-900 dark:text-slate-100 lg:text-2xl">
        Популярні <span class="text-cyan-700 dark:text-rose-400">Відео</span>
      </h2>
      <%= link_to youtube_videos_path, class: 'inline-flex shrink-0 items-baseline gap-0.5 text-md font-medium leading-snug text-cyan-700 transition duration-300 hover:underline dark:text-rose-400' do %>
        <span class="hidden text-sm sm:inline lg:text-base">Більше</span>
        <span aria-hidden="true">&rsaquo;</span>
      <% end %>
    </div>
  </header>

  <div class="flex flex-col gap-3 lg:hidden">
    <%= render 'root/videos_featured_player', video: editorial[:featured] %>
    <%= render 'root/videos_featured_meta', video: editorial[:featured], video_tag_counts: %>

    <div class="grid grid-cols-3 gap-2" role="list" aria-label="Популярні Відео">
      <% editorial[:supporting].each do |video| %>
        <%= render 'root/videos_card', video:, video_tag_counts:, variant: :mobile %>
      <% end %>
    </div>
  </div>

  <div class="hidden lg:grid lg:grid-cols-[minmax(0,1.65fr)_minmax(0,1fr)] lg:grid-rows-[auto_auto] lg:items-stretch lg:gap-x-4 lg:gap-y-3"
       role="list"
       aria-label="Популярні Відео">
    <%= render 'root/videos_featured_player', video: editorial[:featured] %>

    <div class="flex min-h-0 flex-col gap-4">
      <% editorial[:supporting].each do |video| %>
        <%= render 'root/videos_card', video:, video_tag_counts:, variant: :compact %>
      <% end %>
    </div>

    <%= render 'root/videos_featured_meta', video: editorial[:featured], video_tag_counts: %>
    <div aria-hidden="true"></div>
  </div>

  <%= render 'shared/adsense_home_videos_grid' %>
</section>
