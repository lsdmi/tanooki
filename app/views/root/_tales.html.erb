<%# locals: (tales:, top_tale:) %>
<% editorial = home_tales_editorial_cards(top_tale, tales) %>
<% return if editorial[:hero].blank? %>

<section class="mb-10 mt-10 w-full lg:mb-14 lg:mt-14" aria-labelledby="home-tales">
  <div class="home-tales w-full bg-gray-700 bg-cover bg-center bg-no-repeat bg-blend-multiply pt-8 pb-10 lg:pt-14 lg:pb-14 dark:bg-gray-900"
       style="background-image: url(<%= asset_path('writer.webp') %>);">
    <div class="mx-auto w-full max-w-[1300px] px-5 md:px-6 lg:px-20">
      <header class="mb-6 flex items-stretch gap-3 sm:gap-4 lg:mb-8">
        <div class="w-1.5 shrink-0 rounded-lg bg-cyan-500 dark:bg-rose-500" aria-hidden="true"></div>
        <div class="flex min-w-0 flex-1 items-center justify-between gap-4">
          <h2 id="home-tales" class="text-xl font-bold leading-snug tracking-tight text-white lg:text-2xl">
            Новини та <span class="text-cyan-400 dark:text-rose-400">Блоги</span>
          </h2>
          <%= link_to tales_path, class: 'inline-flex shrink-0 items-baseline gap-0.5 text-md font-medium leading-snug text-white transition duration-300 hover:text-cyan-300 hover:underline dark:hover:text-rose-300' do %>
            <span class="hidden text-sm sm:inline lg:text-base">Більше</span>
            <span aria-hidden="true">&rsaquo;</span>
          <% end %>
        </div>
      </header>

      <div class="flex flex-col gap-4 lg:hidden">
        <%= render 'root/tales_card', publication: editorial[:hero], variant: :featured %>

        <% if editorial[:side].any? %>
          <div class="grid grid-cols-2 gap-4" role="list" aria-label="Новини та Блоги">
            <% editorial[:side].each do |publication| %>
              <%= render 'root/tales_card', publication:, variant: :compact %>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="hidden gap-4 lg:grid lg:grid-cols-[minmax(0,1fr)_minmax(0,2.15fr)_minmax(0,1fr)] lg:items-stretch"
           role="list"
           aria-label="Новини та Блоги">
        <div class="flex flex-col gap-4">
          <% editorial[:left].each do |publication| %>
            <%= render 'root/tales_card', publication:, variant: :compact %>
          <% end %>
        </div>

        <div class="flex min-h-0 flex-col">
          <%= render 'root/tales_card', publication: editorial[:hero], variant: :featured %>
        </div>

        <div class="flex flex-col gap-4">
          <% editorial[:right].each do |publication| %>
            <%= render 'root/tales_card', publication:, variant: :compact %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
