<%# locals: fictions:, latest_chapters_by_fiction: %>
<% cards = recently_updated_cards(fictions, latest_chapters_by_fiction) %>

<section class="mb-8 mt-8 lg:mb-14 lg:mt-20" aria-labelledby="home-recently-updated">
  <header class="mb-8 flex items-stretch gap-3 sm:gap-4">
    <div class="w-1.5 shrink-0 rounded-lg bg-cyan-700 dark:bg-rose-500" aria-hidden="true"></div>
    <div class="flex min-w-0 flex-1 items-center justify-between gap-4">
      <h2 id="home-recently-updated" class="text-xl font-bold leading-snug tracking-tight text-stone-900 dark:text-slate-100 lg:text-2xl">
        Нові Релізи
      </h2>
      <%= link_to calendar_fictions_path, class: 'inline-flex shrink-0 items-baseline gap-0.5 text-md font-medium leading-snug text-cyan-700 transition duration-300 hover:underline dark:text-rose-400' do %>
        <span class="hidden text-sm sm:inline lg:text-base">Більше</span>
        <span aria-hidden="true">&rsaquo;</span>
      <% end %>
    </div>
  </header>

  <div
    class="flex snap-x snap-mandatory gap-3 overflow-x-auto overscroll-x-contain [-webkit-overflow-scrolling:touch] -mr-5 sm:hidden"
    role="group"
    aria-label="Нові Релізи">
    <% cards.each_slice(4) do |column_cards| %>
      <%# One column + peek of the next; gap-3 = 12px between columns. Slider only below sm. %>
      <div class="flex w-[78%] shrink-0 snap-start flex-col gap-3">
        <% column_cards.each do |card| %>
          <%= render 'root/recently_updated_card', fiction: card[:fiction], chapter: card[:chapter] %>
        <% end %>
      </div>
    <% end %>
  </div>

  <ul
    class="hidden list-none gap-x-4 gap-y-8 sm:grid sm:grid-cols-2 lg:grid-cols-4"
    aria-label="Нові Релізи">
    <% cards.each do |card| %>
      <li>
        <%= render 'root/recently_updated_card', fiction: card[:fiction], chapter: card[:chapter] %>
      </li>
    <% end %>
  </ul>
</section>
