<% site = StructuredData::SiteProfile %>
<div class="bg-stone-50 dark:bg-gray-800 min-h-screen">
  <div class="container mx-auto px-4 py-8 relative z-10">
    <div class="max-w-4xl mx-auto">
      <header class="bg-white dark:bg-gray-900 rounded-lg shadow-md p-6 mb-8 border border-stone-200 dark:border-gray-700 text-center">
        <h1 class="text-3xl font-bold text-stone-800 dark:text-stone-200 mb-4">Про <%= site::NAME %></h1>
        <p class="text-lg text-stone-600 dark:text-stone-400 leading-relaxed">
          <%= site::DESCRIPTION %>
        </p>
      </header>

      <section class="bg-white dark:bg-gray-900 rounded-lg shadow-md p-6 mb-8 border border-stone-200 dark:border-gray-700">
        <h2 class="text-2xl font-bold text-stone-800 dark:text-stone-200 mb-4">Досвід і спеціалізація</h2>
        <p class="text-stone-700 dark:text-stone-300 leading-relaxed mb-4">
          Працюємо з <%= site::FOUNDING_YEAR %> року. Сайт для тих, хто читає або перекладає ранобе й лайт-новели українською.
          Тут є переклади від українських команд, блоги, відео та добірки від користувачів.
        </p>
        <ul class="list-disc list-inside space-y-2 text-stone-700 dark:text-stone-300">
          <% site::EXPERTISE_TOPICS.each do |topic| %>
            <li><%= topic %></li>
          <% end %>
        </ul>
      </section>

      <section class="bg-white dark:bg-gray-900 rounded-lg shadow-md p-6 mb-8 border border-stone-200 dark:border-gray-700">
        <h2 class="text-2xl font-bold text-stone-800 dark:text-stone-200 mb-4">Редакційні стандарти</h2>
        <div class="space-y-3 text-stone-700 dark:text-stone-300 leading-relaxed">
          <p>
            Кожна публікація має видиме ім'я автора або команди перекладачів із посиланням на профіль.
            Блоги підписуються іменем автора; ранобе та розділи — ім'ям оригінального автора та командою перекладу.
          </p>
          <p>
            Ми дотримуємося <%= link_to 'правил спільноти', rules_path, class: 'text-cyan-700 dark:text-rose-400 hover:underline' %>
            щодо мови контенту, авторських прав і якості публікацій.
          </p>
        </div>
      </section>

      <section class="bg-white dark:bg-gray-900 rounded-lg shadow-md p-6 border border-stone-200 dark:border-gray-700">
        <h2 class="text-2xl font-bold text-stone-800 dark:text-stone-200 mb-4">Контакти</h2>
        <p class="text-stone-700 dark:text-stone-300 leading-relaxed">
          З питаннями щодо платформи, співпраці або скарг звертайтеся до нас у
          <%= link_to 'Telegram', site::SOCIAL_URLS.first, class: 'text-cyan-700 dark:text-rose-400 hover:underline', target: '_blank', rel: 'noopener noreferrer' %>.
        </p>
      </section>
    </div>
  </div>
</div>
