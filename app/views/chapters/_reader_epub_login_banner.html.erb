<%# locals: fiction: %>
<section class="reader-epub-banner w-full rounded-lg border border-stone-200/90 bg-white/95 p-3 shadow-sm dark:border-rose-900/50 dark:bg-zinc-900/95 sm:rounded-xl sm:p-4 md:p-5"
         aria-labelledby="reader-epub-banner-title">
  <%# Mobile: copy then full-width button. md+: copy left, button right. %>
  <div class="flex w-full flex-col gap-3 md:flex-row md:items-center md:justify-between md:gap-6">
    <div class="flex min-w-0 flex-1 gap-2.5 sm:gap-3 md:gap-4">
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-cyan-800/80 bg-white dark:border-rose-600/55 dark:bg-zinc-950 sm:h-11 sm:w-11"
           aria-hidden="true">
        <svg class="h-5 w-5 text-cyan-800 dark:text-rose-300 sm:h-6 sm:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 10v4m0 0l-2-2m2 2l2-2" />
        </svg>
      </div>

      <div class="min-w-0 flex-1">
        <div class="flex flex-wrap items-center gap-2">
          <h2 id="reader-epub-banner-title" class="text-sm font-bold text-cyan-900 dark:text-zinc-50 sm:text-base md:text-lg">
            <%= t('chapters.reader_epub_banner.title') %>
          </h2>
          <span class="rounded border border-cyan-800/70 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-cyan-800 dark:border-rose-500/65 dark:bg-rose-950/40 dark:text-rose-200">
            EPUB
          </span>
        </div>
        <p class="mt-1 text-xs leading-snug text-stone-600 dark:text-zinc-400 sm:text-sm">
          <%= t('chapters.reader_epub_banner.login_description') %>
        </p>
      </div>
    </div>

    <%= ui_button(as: :link,
                  href: new_user_session_path,
                  full_width: true,
                  size: :md,
                  html: { class: 'md:w-auto' }) do %>
      <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 4h4a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2h-4" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12h12" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 17l5-5-5-5" />
      </svg>
      <%= t('downloads.epub_export.login_link_text') %>
    <% end %>
  </div>
</section>
