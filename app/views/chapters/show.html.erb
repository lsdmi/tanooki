<div class="immersive-reader bg-stone-100 dark:bg-zinc-950 min-h-screen relative"
     data-controller="comments-toggle jump-to-top chapter-drawer reader-settings<%= ' reader-ad-drawer' if chapter_reader_ad_drawer_live? %>"
     <% if chapter_reader_ad_drawer_live? %>
     data-reader-ad-drawer-should-open-value="<%= @reader_ad_drawer_open %>"
     data-reader-ad-drawer-auto-close-ms-value="10000"
     data-reader-ad-drawer-countdown-template-value="<%= t('chapters.reader_ad_drawer.countdown', seconds: '__SECONDS__') %>"
     <% end %>>
  <div class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat" style="background-image: url('<%= url_for(@chapter.fiction.cover) %>');"></div>
  <div class="absolute inset-0 z-[1] bg-stone-100/90 dark:bg-zinc-950/90"></div>

  <%= render 'reader_ad_drawer' if chapter_reader_ad_drawer_live? %>
  <%= render 'reader_settings_drawer', chapter: @chapter %>

  <main class="relative z-10">
    <%= render 'reader_toolbar', chapter: @chapter, fiction: @chapter.fiction %>
    <%= render 'hero', chapter: @chapter, fiction: @chapter.fiction %>

    <% if epub_download_requires_login?(@chapter) %>
      <div class="container mx-auto px-4 py-4">
        <%= render 'reader_epub_login_banner', fiction: @chapter.fiction %>
      </div>
    <% end %>

    <!-- Main Content and Comments -->
    <div class="container mx-auto px-4 py-2 sm:py-4 lg:py-8">
      <%= render 'fictions/adult_content_disclaimer', fiction: @chapter.fiction if show_adult_content_disclaimer?(@chapter.fiction) %>

      <div class="flex flex-col lg:flex-row gap-6 sm:gap-8 lg:gap-12">
        <!-- Content Section -->
        <div data-comments-toggle-target="contentSection" class="w-full lg:w-full">
          <%= render @chapter, previous_chapter: @previous_chapter, next_chapter: @next_chapter %>
        </div>

        <!-- Comments Section - Desktop Sidebar -->
        <div data-comments-toggle-target="commentsSection" class="reader-comments hidden w-full lg:w-1/3 mt-8 lg:mt-0 transition-all duration-300">
          <!-- Support Creator Section -->
          <% if @chapter.fiction.scanlators.pluck(:bank_url).compact_blank.any? %>
            <%= render 'fictions/support', fiction: @chapter.fiction %>
          <% end %>

          <%= render 'comments/index', comments: @comments, comment: @comment, commentable: @commentable %>
        </div>
      </div>
    </div>

    <%= render 'reader_copyright' %>
  </main>

  <button type="button"
          id="jump-to-top"
          class="fixed z-40 bottom-4 right-4 hidden rounded-full border border-stone-200/90 bg-stone-50/95 p-2.5 text-stone-700 shadow-md shadow-stone-900/10 transition-opacity dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200 dark:shadow-black/40 sm:bottom-6 sm:right-6"
          title="Догори"
          aria-label="Прокрутити догори">
    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
    </svg>
  </button>

  <% if fiction_has_listable_chapters?(@chapter.fiction, current_user) %>
    <%= render "chapter_drawer",
               fiction: @chapter.fiction,
               order: @fiction_sidebar_presenter.order,
               toggle_order_button_id: "toggle-fictions-order-drawer",
               current_chapter: @chapter %>
  <% end %>
</div>
