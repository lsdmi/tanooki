<section class="w-full rounded-lg bg-stone-50/95 ring-1 ring-stone-200/80 shadow-sm dark:bg-zinc-900 dark:shadow-none dark:ring-zinc-800 p-4 sm:p-6 lg:p-8 transition-shadow duration-300 hover:shadow-md dark:hover:shadow-none relative overflow-hidden">
  <%= render "chapter_navigation", previous_chapter: previous_chapter, next_chapter: next_chapter, placement: :top %>
  <div class="absolute top-0 left-0 w-full h-2 bg-stone-300/90 dark:bg-zinc-700"></div>

  <div id="user-content" class="prose dark:prose-invert max-w-none text-base sm:text-lg leading-relaxed text-stone-800 dark:text-zinc-200">
    <%= chapter.content %>
  </div>

  <%= render "chapter_navigation", previous_chapter: previous_chapter, next_chapter: next_chapter %>
</section>
