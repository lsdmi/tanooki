<section class="w-full rounded-lg bg-stone-50/95 ring-1 ring-stone-200/80 shadow-sm dark:bg-zinc-900 dark:shadow-none dark:ring-zinc-700 p-3 sm:p-6 lg:p-8 transition-shadow duration-300 hover:shadow-md dark:hover:shadow-none relative overflow-hidden">
  <%= render "chapter_navigation", previous_chapter: previous_chapter, next_chapter: next_chapter, placement: :top %>
  <%= render "shared/adsense_chapter_reader_slot", placement: :top %>
  <div class="absolute top-0 left-0 w-full h-2 bg-cyan-700 dark:bg-rose-600"></div>

  <div id="user-content" class="prose dark:prose-invert max-w-none text-base sm:text-lg leading-relaxed text-stone-800 dark:text-zinc-200" data-controller="note-reference" data-action="click->note-reference#toggle">
    <%= chapter.content %>
  </div>

  <%= render "shared/adsense_chapter_reader_slot", placement: :bottom %>
  <%= render "chapter_navigation", previous_chapter: previous_chapter, next_chapter: next_chapter, placement: :bottom %>
  <%= render "reader_bottom_section", chapter: chapter, fiction: chapter.fiction %>
</section>
