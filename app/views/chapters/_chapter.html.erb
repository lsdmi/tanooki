<section class="w-full bg-white dark:bg-gray-800 rounded-lg shadow-md p-4 sm:p-6 lg:p-8 transition-all duration-300 hover:shadow-lg relative overflow-hidden">
  <%= render "chapter_navigation", previous_chapter: previous_chapter, next_chapter: next_chapter, placement: :top %>
  <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-stone-300 to-stone-400 dark:from-gray-600 dark:to-gray-700"></div>

  <div id="user-content" class="prose dark:prose-invert max-w-none text-base sm:text-lg leading-relaxed text-stone-700 dark:text-gray-300">
    <%= chapter.content %>
  </div>

  <%= render "chapter_navigation", previous_chapter: previous_chapter, next_chapter: next_chapter %>
</section>
