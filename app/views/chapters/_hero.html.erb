<% chapter_meta_link_class = 'inline-block max-w-full truncate sm:max-w-md font-medium text-stone-600 dark:text-zinc-300 hover:text-stone-800 dark:hover:text-zinc-100 transition-colors duration-300 rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-stone-400/50 dark:focus-visible:ring-zinc-500/50' %>
<section class="relative mt-8 border-b border-stone-300 dark:border-zinc-700">
  <div class="container mx-auto px-4 pb-4 pt-0 sm:pb-5">
    <nav class="mb-3 text-[11px] sm:text-xs text-stone-600 dark:text-zinc-400" aria-label="Навігація">
      <ol class="flex flex-wrap items-center gap-x-1.5 gap-y-0.5 leading-snug">
        <li><%= link_to 'Головна', root_path, class: 'rounded-sm hover:text-stone-800 dark:hover:text-zinc-200 transition-colors duration-300' %></li>
        <li class="text-stone-400 dark:text-zinc-500 select-none" aria-hidden="true">·</li>
        <li><%= link_to 'Ранобе', fictions_path, class: 'rounded-sm hover:text-stone-800 dark:hover:text-zinc-200 transition-colors duration-300' %></li>
        <li class="text-stone-400 dark:text-zinc-500 select-none" aria-hidden="true">·</li>
        <li class="min-w-0 font-medium">
          <%= link_to fiction.title, fiction_path(fiction), class: 'text-stone-700 dark:text-zinc-300 hover:text-stone-800 dark:hover:text-zinc-100 transition-colors duration-300 line-clamp-2 sm:line-clamp-1' %>
        </li>
      </ol>
    </nav>

    <div class="min-w-0">
      <h1 class="text-2xl sm:text-3xl md:text-[2rem] font-bold text-stone-900 dark:text-zinc-50 leading-snug tracking-tight">
        <% if title_includes_rozdil?(chapter.title) %>
          <%= chapter.title.presence || chapter.display_title %>
        <% else %>
          Розділ <%= format_decimal(chapter.number) %><% if chapter.title? || chapter.display_title.present? %> — <%= chapter.title.presence || chapter.display_title %><% end %>
        <% end %>
      </h1>

      <div class="mt-2.5 flex flex-wrap items-baseline gap-x-2 gap-y-1 text-sm">
        <%= render 'shared/author_byline',
                   name: fiction.author,
                   url: search_index_path(search: [fiction.author]),
                   link_class: chapter_meta_link_class %>
        <% if chapter.scanlators.any? %>
          <span class="text-stone-400 dark:text-zinc-500 select-none" aria-hidden="true">·</span>
          <% chapter.scanlators.each_with_index do |scanlator, i| %>
            <%= tag.span ', ', class: 'text-stone-400 dark:text-zinc-500 select-none' if i.positive? %>
            <%= link_to scanlator.title, scanlator_path(scanlator), class: chapter_meta_link_class %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</section>
