<%# Section cannot use overflow-hidden: it clips the mobile fixed action bar. %>
<%# Toolbar: light = airy chip; dark = genre card chip (slate-800). %>
<% action_icon = 'p-1.5 rounded-md text-slate-600 transition-colors hover:bg-slate-200/90 hover:text-slate-900 focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:text-slate-200 dark:hover:bg-slate-700/90 dark:hover:text-white dark:focus-visible:ring-rose-500 dark:focus-visible:ring-offset-slate-900' %>
<% chapter_meta_link_class = 'inline-block max-w-full truncate sm:max-w-md font-medium text-stone-600 dark:text-gray-400 hover:text-stone-800 dark:hover:text-gray-200 transition-colors duration-300 rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-stone-400/50 dark:focus-visible:ring-gray-500/50' %>
<section class="relative border-b border-stone-200 dark:border-gray-700">
  <div class="container mx-auto px-4 py-4 sm:py-5">
    <nav class="mb-3 text-[11px] sm:text-xs text-stone-600 dark:text-gray-400" aria-label="Навігація">
      <ol class="flex flex-wrap items-center gap-x-1.5 gap-y-0.5 leading-snug">
        <li><%= link_to 'Головна', root_path, class: 'rounded-sm hover:text-stone-800 dark:hover:text-gray-200 transition-colors duration-300' %></li>
        <li class="text-stone-400 dark:text-gray-600 select-none" aria-hidden="true">·</li>
        <li><%= link_to 'Ранобе', fictions_path, class: 'rounded-sm hover:text-stone-800 dark:hover:text-gray-200 transition-colors duration-300' %></li>
        <li class="text-stone-400 dark:text-gray-600 select-none" aria-hidden="true">·</li>
        <li class="min-w-0 font-medium">
          <%= link_to fiction.title, fiction_path(fiction), class: 'hover:text-stone-800 dark:hover:text-gray-200 transition-colors duration-300 line-clamp-2 sm:line-clamp-1' %>
        </li>
      </ol>
    </nav>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
      <div class="min-w-0 flex-1 pr-2">
        <h1 class="text-2xl sm:text-3xl md:text-[2rem] font-bold text-stone-900 dark:text-gray-100 leading-snug tracking-tight">
          <% if title_includes_rozdil?(chapter.title) %>
            <%= chapter.title.presence || chapter.display_title %>
          <% else %>
            Розділ <%= check_decimal(chapter.number) %><% if chapter.title.present? || chapter.display_title.present? %> — <%= chapter.title.presence || chapter.display_title %><% end %>
          <% end %>
        </h1>

        <div class="mt-2.5 flex flex-wrap items-baseline gap-x-2 gap-y-1 text-sm">
          <%= link_to fiction.author, search_index_path(search: [fiction.author]), class: chapter_meta_link_class %>
          <% if chapter.scanlators.any? %>
            <span class="text-stone-400 dark:text-gray-600 select-none" aria-hidden="true">·</span>
            <% chapter.scanlators.each_with_index do |scanlator, i| %>
              <%= tag.span ', ', class: 'text-stone-400 dark:text-gray-600 select-none' if i.positive? %>
              <%= link_to scanlator.title, scanlator_path(scanlator), class: chapter_meta_link_class %>
            <% end %>
          <% end %>
        </div>
      </div>

      <div class="fixed z-50 bottom-3 left-3 flex flex-wrap items-center gap-1 rounded-md border border-slate-300/70 bg-white/95 px-1.5 py-1 shadow-md shadow-slate-400/20 sm:bottom-4 sm:left-4 lg:static lg:z-auto lg:bottom-auto lg:left-auto lg:shrink-0 lg:self-start dark:border-slate-500/45 dark:bg-slate-800/85 dark:shadow-lg dark:shadow-slate-900/25 lg:dark:shadow-md lg:dark:shadow-slate-900/20">
        <% if fiction_has_listable_chapters?(fiction, current_user) %>
          <button type="button"
                  class="<%= action_icon %>"
                  data-action="click->chapter-drawer#open"
                  title="Список розділів"
                  aria-label="Відкрити список розділів">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h10M4 18h10" />
            </svg>
          </button>
        <% end %>
        <% if chapter_epub_download_allowed?(chapter) %>
          <div data-controller="epub-download" data-epub-download-url-value="<%= epub_download_path(chapter.content) %>">
            <button type="button" data-epub-download-target="button" data-action="click->epub-download#download" class="<%= action_icon %>" title="Завантажити EPUB">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
            </button>
          </div>
        <% end %>
        <%= link_to edit_chapter_path(chapter), class: action_icon, title: 'Редагувати розділ' do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
        <% end if current_user && current_user.admin? || current_user == chapter.user %>
        <button type="button" id="font-toggle" class="<%= action_icon %>" title="Змінити шрифт">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
          </svg>
        </button>
        <button type="button" id="font-size-toggle" class="<%= action_icon %>" title="Змінити розмір">
          <svg class="h-5 w-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m22 6-3-4-3 4h2v4h-2l3 4 3-4h-2V6zM9.307 4l-6 16h2.137l1.875-5h6.363l1.875 5h2.137l-6-16H9.307zm-1.239 9L10.5 6.515 12.932 13H8.068z" /></svg>
        </button>
        <button type="button" data-action="click->comments-toggle#toggle" class="<%= action_icon %>" title="Коментарі">
          <svg data-comments-toggle-target="icon" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
        </button>
        <button type="button" id="jump-to-top" onclick="window.scrollTo({top: 0, behavior: 'smooth'})" class="<%= action_icon %> lg:hidden" title="Догори">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>
