<%# locals: chapter:, fiction: %>
<% action_icon = 'p-1.5 rounded-md text-stone-600 transition-colors hover:bg-stone-200/90 hover:text-stone-900 focus:outline-none focus-visible:ring-2 focus-visible:ring-stone-400/80 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50 dark:text-zinc-300 dark:hover:bg-zinc-800/80 dark:hover:text-zinc-50 dark:focus-visible:ring-rose-500/80 dark:focus-visible:ring-offset-zinc-950' %>
<header class="sticky top-0 z-50 border-b border-stone-200/70 bg-stone-50/90 backdrop-blur-sm dark:border-zinc-800 dark:bg-zinc-950">
  <div class="container mx-auto flex items-center justify-between gap-2 px-4 py-2 sm:py-2.5">
    <div class="flex shrink-0 items-center gap-0.5 sm:gap-1">
      <%= link_to root_path, class: action_icon, title: 'Головна', aria: { label: 'На головну' } do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
      <% end %>
      <%= link_to fiction_path(fiction), class: action_icon, title: 'До сторінки ранобе', aria: { label: 'Назад до ранобе' } do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      <% end %>
    </div>

    <div class="flex min-w-0 flex-wrap items-center justify-end gap-0.5 sm:gap-1">
      <% if fiction_has_listable_chapters?(fiction, current_user) %>
        <button type="button"
                class="<%= action_icon %>"
                data-action="click->chapter-drawer#open"
                title="Список розділів"
                aria-label="Відкрити список розділів">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h10M4 18h10" />
          </svg>
        </button>
      <% end %>
      <% if epub_download_available?(chapter) %>
        <div data-controller="epub-download" data-epub-download-url-value="<%= epub_download_path(chapter.content) %>">
          <button type="button" data-epub-download-target="button" data-action="click->epub-download#download" class="<%= action_icon %>" title="Завантажити EPUB" aria-label="Завантажити EPUB">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
          </button>
        </div>
      <% end %>
      <button type="button" data-action="click->comments-toggle#toggle" class="<%= action_icon %> relative" title="Коментарі" aria-label="Коментарі">
        <svg data-comments-toggle-target="icon" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
        <% if chapter.comments_count.positive? %>
          <span class="absolute -right-0.5 -top-0.5 flex h-4 min-w-[1rem] items-center justify-center rounded-full bg-cyan-600 px-1 text-[10px] font-semibold leading-none text-white dark:bg-rose-600">
            <%= chapter.comments_count > 99 ? '99+' : chapter.comments_count %>
          </span>
        <% end %>
      </button>
      <div class="relative" data-controller="reader-settings">
        <button type="button"
                class="<%= action_icon %>"
                data-action="click->reader-settings#toggle"
                title="Налаштування читання"
                aria-label="Налаштування читання"
                aria-expanded="false"
                data-reader-settings-target="trigger">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </button>
        <div data-reader-settings-target="panel"
             class="absolute right-0 top-full z-10 mt-1 hidden w-52 rounded-lg border border-stone-200/80 bg-stone-50 py-1 shadow-lg shadow-stone-900/5 dark:border-zinc-700 dark:bg-zinc-900 dark:shadow-black/30"
             role="menu"
             aria-label="Налаштування читання">
          <button type="button" id="font-toggle" class="flex w-full items-center gap-2 px-3 py-2 text-left text-sm text-stone-700 hover:bg-stone-100 dark:text-zinc-200 dark:hover:bg-zinc-800/80" role="menuitem">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
            </svg>
            Змінити шрифт
          </button>
          <button type="button" id="font-size-toggle" class="flex w-full items-center gap-2 px-3 py-2 text-left text-sm text-stone-700 hover:bg-stone-100 dark:text-zinc-200 dark:hover:bg-zinc-800/80" role="menuitem">
            <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor" aria-hidden="true"><path d="m22 6-3-4-3 4h2v4h-2l3 4 3-4h-2V6zM9.307 4l-6 16h2.137l1.875-5h6.363l1.875 5h2.137l-6-16H9.307zm-1.239 9L10.5 6.515 12.932 13H8.068z" /></svg>
            Розмір тексту
          </button>
          <button type="button"
                  id="reader-theme-toggle"
                  class="flex w-full items-center gap-2 px-3 py-2 text-left text-sm text-stone-700 hover:bg-stone-100 dark:text-zinc-200 dark:hover:bg-zinc-800/80"
                  role="menuitem"
                  aria-label="Змінити тему">
            <svg id="reader-theme-toggle-dark-icon" class="h-4 w-4 shrink-0 hidden" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
            </svg>
            <svg id="reader-theme-toggle-light-icon" class="h-4 w-4 shrink-0 hidden" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path>
            </svg>
            <span id="reader-theme-toggle-label">Темна тема</span>
          </button>
          <% if current_user && (current_user.admin? || current_user == chapter.user) %>
            <%= link_to edit_chapter_path(chapter),
                        class: 'flex w-full items-center gap-2 px-3 py-2 text-left text-sm text-stone-700 hover:bg-stone-100 dark:text-zinc-200 dark:hover:bg-zinc-800/80',
                        role: 'menuitem' do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
              Редагувати розділ
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</header>
