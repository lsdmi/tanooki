<%# locals: chapter:, fiction: %>
<% action_icon = 'p-1.5 rounded-md text-stone-600 transition-colors hover:bg-stone-200/90 hover:text-stone-900 focus:outline-none focus-visible:ring-2 focus-visible:ring-stone-400/80 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50 dark:text-zinc-300 dark:hover:bg-zinc-800/80 dark:hover:text-zinc-50 dark:focus-visible:ring-rose-500/80 dark:focus-visible:ring-offset-zinc-950' %>
<header class="reader-toolbar sticky top-0 z-50 border-b border-stone-200/70 bg-stone-50/90 py-4 backdrop-blur-sm transition-transform duration-200 ease-out will-change-transform dark:border-zinc-700 dark:bg-zinc-950"
        data-controller="reader-toolbar"
        data-reader-toolbar-hidden-class="-translate-y-full pointer-events-none">
  <div class="container mx-auto px-4">
    <div class="flex min-h-10 items-center justify-between gap-2 md:min-h-14">
    <div class="flex shrink-0 items-center gap-0.5 sm:gap-1">
      <%= link_to root_path, class: action_icon, title: 'Головна', aria: { label: 'На головну' } do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
      <% end %>
      <%= link_to fiction_path(fiction), class: action_icon, title: 'До сторінки ранобе', aria: { label: 'Назад до ранобе' } do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      <% end %>
    </div>

    <div class="flex min-w-0 flex-wrap items-center justify-end gap-0.5 sm:gap-1">
      <% if fiction_has_listable_chapters?(fiction, current_user) %>
        <button type="button"
                class="<%= action_icon %>"
                data-action="click->chapter-drawer#open"
                title="<%= t('chapters.reader_chapter_drawer.sections_heading') %>"
                aria-label="<%= t('chapters.reader_chapter_drawer.sections_heading') %>"
                aria-expanded="false"
                aria-controls="reader-chapter-list-panel"
                data-chapter-drawer-target="trigger">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h10M4 18h10" />
          </svg>
        </button>
      <% end %>
      <% if epub_download_available?(chapter) %>
        <div data-controller="epub-download" data-epub-download-url-value="<%= epub_download_path(chapter.content) %>">
          <button type="button" data-epub-download-target="button" data-action="click->epub-download#download" class="<%= action_icon %>" title="Завантажити EPUB" aria-label="Завантажити EPUB">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
          </button>
        </div>
      <% end %>
      <button type="button"
              data-action="click->comments-drawer#open"
              class="<%= action_icon %> relative"
              title="<%= t('chapters.reader_comments_drawer.title') %>"
              aria-label="<%= t('chapters.reader_comments_drawer.title') %>"
              aria-expanded="false"
              aria-controls="reader-comments-panel"
              data-comments-drawer-target="trigger">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
        <span id="reader-comments-badge">
          <%= render 'chapters/reader_comments_badge', chapter: chapter %>
        </span>
      </button>
      <button type="button"
              class="<%= action_icon %>"
              data-action="click->reader-settings#open"
              title="<%= t('chapters.reader_settings.title') %>"
              aria-label="<%= t('chapters.reader_settings.title') %>"
              aria-expanded="false"
              aria-controls="reader-settings-panel"
              data-reader-settings-target="trigger">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </button>
    </div>
    </div>
  </div>
</header>
