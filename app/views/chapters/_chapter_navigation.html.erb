<% placement = local_assigns.fetch(:placement, :bottom) %>
<% if previous_chapter.present? || next_chapter.present? %>
  <% nav_btn_class = 'reader-chapter-nav__btn inline-flex min-w-0 flex-1 items-center justify-center gap-0.5 rounded-md border border-stone-200 bg-white px-2 py-1.5 text-[11px] font-medium leading-tight text-stone-700 shadow-sm transition-colors hover:border-stone-300 hover:bg-stone-50 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200 dark:hover:border-zinc-600 dark:hover:bg-zinc-800/80 sm:flex-none sm:gap-1 sm:rounded-lg sm:px-4 sm:py-2.5 sm:text-sm' %>
  <nav class="<%= placement == :top ? 'reader-chapter-nav reader-chapter-nav--top mt-3 sm:mt-4 mb-3 sm:mb-6' : 'reader-chapter-nav reader-chapter-nav--bottom mt-4 border-t border-stone-300 pt-3 dark:border-zinc-700/60 sm:mt-8 sm:pt-6' %>"
       aria-label="<%= placement == :top ? 'Навігація розділів (зверху)' : 'Навігація розділів (знизу)' %>">
    <div class="flex flex-row items-stretch justify-between gap-1.5 sm:gap-3">
      <% if previous_chapter.present? %>
        <%= link_to chapter_path(previous_chapter), turbo_drive_visit_data(preload: true).merge(class: "#{nav_btn_class} sm:justify-start") do %>
          <svg class="h-3 w-3 shrink-0 sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          <span class="truncate">Попередній розділ</span>
        <% end %>
      <% else %>
        <span class="hidden flex-1 sm:block sm:flex-none sm:w-0" aria-hidden="true"></span>
      <% end %>

      <% if next_chapter.present? %>
        <%= link_to chapter_path(next_chapter), turbo_drive_visit_data(preload: true).merge(class: "#{nav_btn_class} sm:justify-end") do %>
          <span class="truncate">Наступний розділ</span>
          <svg class="h-3 w-3 shrink-0 sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        <% end %>
      <% else %>
        <span class="hidden flex-1 sm:block sm:flex-none sm:w-0" aria-hidden="true"></span>
      <% end %>
    </div>
  </nav>
<% end %>
